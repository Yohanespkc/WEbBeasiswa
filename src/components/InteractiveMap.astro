---
import { BUDAYA_REGISTRY } from '../data/budayaRegistry';
import { KABUPATEN_DATA, SISWA_DATA } from '../data/statistikRegistry';

const regionsJson = JSON.stringify(BUDAYA_REGISTRY);
const kabupatenDataJson = JSON.stringify(KABUPATEN_DATA);
const siswaDataJson = JSON.stringify(SISWA_DATA);
---

<div class="map-card glass-panel">
  <div class="map-header">
    <h3>🗺️ Peta Dampak Pelatihan GASING Nusantara</h3>
    <p>Sentuh atau klik titik pada peta untuk melihat bukti nyata perubahan numerasi anak-anak bangsa di daerah tersebut.</p>
  </div>

  <div class="map-canvas-container relative">
    <div class="map-loading">
      <div class="spinner"></div>
      <p>Memuat Peta Nusantara...</p>
    </div>
    <!-- SVG Indonesia Map will be injected dynamically here -->
  </div>

  <div class="map-legend">
    <div class="legend-item">
      <span class="legend-dot active-dot"></span>
      <span>127+ Wilayah Sukses Terintervensi</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot waiting-dot"></span>
      <span>387 Wilayah Menunggu Dukungan Anda</span>
    </div>
  </div>

  <!-- Custom Tooltip -->
  <div class="map-tooltip opacity-0 pointer-events-none absolute z-[80] glass-panel p-4" id="map-tooltip">
    <h4 class="tooltip-title text-gold font-serif">Kabupaten</h4>
    <p class="tooltip-region text-muted text-xs uppercase tracking-wider mb-2">Papua</p>
    <div class="tooltip-stats">
      <div class="tooltip-stat">
        <span class="stat-lbl">Peningkatan:</span>
        <span class="stat-val text-success">10.04x Lipat</span>
      </div>
      <div class="tooltip-stat">
        <span class="stat-lbl">Metode:</span>
        <span class="stat-val text-white">GASING Hore</span>
      </div>
    </div>
    <p class="tooltip-helper text-muted text-[10px] mt-2 italic">*Klik untuk melihat statistik & memutar video</p>
  </div>

  <!-- Detail & Video Modal -->
  <div class="video-modal pointer-events-none opacity-0 fixed inset-0 z-[100] flex items-center justify-center p-6 bg-slate-950/85 backdrop-blur-md transition-all duration-300" id="video-modal">
    <div class="modal-card glass-panel p-6 max-w-5xl w-full relative">
      <button class="modal-close-btn" id="modal-close-btn">✖</button>
      <h3 class="modal-title font-serif text-xl text-center text-gold mb-4">Pelatihan GASING di Kabupaten</h3>
      
      <!-- Combined Layout Grid -->
      <div class="modal-grid">
        <!-- Left Pane: Video Player -->
        <div class="modal-col-video">
          <div class="video-wrapper">
            <iframe
              id="modal-iframe"
              class="w-full aspect-video rounded-xl border border-white/10"
              src=""
              title="Video Pelatihan GASING"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <p class="text-xs text-muted text-center mt-3">Mendengar keceriaan anak-anak belajar numerasi lewat melodi lagu daerah mereka.</p>
        </div>

        <!-- Right Pane: Statistics Graphs -->
        <div class="modal-col-stats">
          <div class="flex justify-between items-center mb-3">
            <h4 class="text-xs font-black uppercase tracking-wider text-indigo-300" style="margin: 0; font-family: Inter, sans-serif;">📈 Hasil Pretest dan Posttest Pelatihan GASING</h4>
            <!-- Chart Type Selectors -->
            <div class="grafana-chart-type-selector">
              <button class="chart-type-btn active" id="btn-chart-bar">📊 Batang</button>
              <button class="chart-type-btn" id="btn-chart-line">📈 Garis</button>
            </div>
          </div>
          
          <!-- Toggle Tabs -->
          <div class="modal-tabs">
            <button class="modal-tab-btn active" id="btn-tab-guru">👨‍🏫 Data Guru</button>
            <button class="modal-tab-btn" id="btn-tab-siswa">👨‍🎓 Data Siswa</button>
          </div>
          
          <!-- Participant Count -->
          <div class="stats-peserta-label" id="stats-peserta-label">
            Jumlah Peserta: <span class="text-gold font-bold" id="stats-peserta-count">-</span>
          </div>

          <!-- Integrated Chart Canvas -->
          <div class="grafana-chart-canvas" id="grafana-chart-canvas">
            <!-- Dynamic SVG injected here -->
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ regionsJson, kabupatenDataJson, siswaDataJson }}>
  // Parse regions and stats data passed from Astro
  const regions = JSON.parse(regionsJson);
  const kabupatenData = JSON.parse(kabupatenDataJson);
  const siswaData = JSON.parse(siswaDataJson);

  class InteractiveMap {
    constructor(container) {
      this.container = container;
      this.canvasContainer = container.querySelector('.map-canvas-container');
      this.loadingEl = container.querySelector('.map-loading');
      this.tooltip = document.getElementById('map-tooltip');
      this.modal = document.getElementById('video-modal');
      this.modalClose = document.getElementById('modal-close-btn');
      this.iframe = document.getElementById('modal-iframe');

      this.currentKabName = '';
      this.currentActiveTab = 'guru'; // default tab
      this.currentChartType = 'bar'; // default chart type

      this.init();
    }

    async init() {
      await this.loadMap();
      this.renderPins();
      this.setupModalEvents();
    }

    async loadMap() {
      try {
        const res = await fetch('/indonesia.svg');
        const svgText = await res.text();
        
        // Remove loading state
        if (this.loadingEl) this.loadingEl.remove();

        // Parse and append SVG
        const parser = new DOMParser();
        const doc = parser.parseFromString(svgText, 'image/svg+xml');
        const svgEl = doc.querySelector('svg');
        
        if (svgEl) {
          // Adjust class for responsiveness
          svgEl.setAttribute('class', 'w-full h-auto drop-shadow-2xl');
          svgEl.removeAttribute('style');
          
          // Create markers group
          const markersGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
          markersGroup.setAttribute('id', 'markers-container');
          svgEl.appendChild(markersGroup);

          this.canvasContainer.appendChild(svgEl);
          this.svg = svgEl;
          this.markersContainer = markersGroup;
        }
      } catch (e) {
        console.error("Gagal memuat peta Indonesia SVG:", e);
      }
    }

    findStats(kabName) {
      const clean = (s) => s.toLowerCase().replace(/^(kab|kabupaten|kota)\.?\s+/g, '').trim();
      const cleanName = clean(kabName);
      
      const gEntry = kabupatenData.find(d => clean(d.kabupaten) === cleanName);
      const sEntry = siswaData.find(d => clean(d.kabupaten) === cleanName);
      
      return { gEntry, sEntry };
    }

    renderPins() {
      if (!this.markersContainer) return;

      regions.forEach((reg) => {
        // Create a group for the pin
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.setAttribute('class', 'map-pin cursor-pointer');
        g.setAttribute('data-name', reg.name);
        g.setAttribute('data-id', reg.id);
        
        // Dynamic mock statistics based on regional history
        let increase = '3.5x Lipat';
        let province = 'Indonesia';
        if (reg.y > 200 && reg.x > 800) {
          increase = '10.04x Lipat';
          province = 'Papua';
        } else if (reg.x < 200) {
          increase = '4.8x Lipat';
          province = 'Sumatera';
        } else if (reg.x > 250 && reg.x < 420 && reg.y > 280) {
          increase = '5.6x Lipat';
          province = 'Jawa';
        } else if (reg.x > 500 && reg.x < 680 && reg.y > 100 && reg.y < 260) {
          increase = '6.2x Lipat';
          province = 'Sulawesi';
        } else if (reg.x > 500 && reg.x < 650 && reg.y > 320) {
          increase = '7.5x Lipat';
          province = 'Nusa Tenggara';
        }

        g.setAttribute('data-increase', increase);
        g.setAttribute('data-province', province);

        // Central active gold/yellow dot
        const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        dot.setAttribute('cx', reg.x.toString());
        dot.setAttribute('cy', reg.y.toString());
        dot.setAttribute('r', '3.5');
        dot.setAttribute('fill', '#fbbf24');
        dot.setAttribute('stroke', '#ffffff');
        dot.setAttribute('stroke-width', '1');

        g.appendChild(dot);

        // Hover events
        g.addEventListener('mouseenter', (e) => this.showTooltip(e, reg.name, province, increase));
        g.addEventListener('mouseleave', () => this.hideTooltip());
        g.addEventListener('mousemove', (e) => this.moveTooltip(e));

        // Click events
        g.addEventListener('click', () => this.playVideo(reg.id, reg.name));

        this.markersContainer.appendChild(g);
      });
    }

    showTooltip(e, name, province, defaultIncrease) {
      if (!this.tooltip) return;
      
      const { gEntry, sEntry } = this.findStats(name);
      
      this.tooltip.querySelector('.tooltip-title').textContent = `Kab. ${name}`;
      this.tooltip.querySelector('.tooltip-region').textContent = province;
      
      // Calculate dynamic tooltip stats from Excel D1 cache
      let increaseHtml = '';
      if (gEntry || sEntry) {
        if (gEntry) {
          const pre = gEntry.bakalkubagiPre;
          const post = gEntry.bakalkubagiPost;
          const pct = pre > 0 ? ((post - pre) / pre * 100) : 0;
          increaseHtml += `<div>👨‍🏫 Guru: ${pre.toFixed(1)} ➔ ${post.toFixed(1)} (+${pct.toFixed(0)}%)</div>`;
        }
        if (sEntry) {
          const pre = sEntry.bakalkubagiPre;
          const post = sEntry.bakalkubagiPost;
          const pct = pre > 0 ? ((post - pre) / pre * 100) : 0;
          increaseHtml += `<div style="margin-top: 4px;">👨‍🎓 Siswa: ${pre.toFixed(1)} ➔ ${post.toFixed(1)} (+${pct.toFixed(0)}%)</div>`;
        }
      } else {
        increaseHtml = `<div>Peningkatan: ${defaultIncrease}</div>`;
      }
      
      this.tooltip.querySelector('.stat-val').innerHTML = increaseHtml;
      
      // Set secondary statistic line
      const methodValEl = this.tooltip.querySelectorAll('.stat-val')[1];
      if (methodValEl) {
        if (gEntry || sEntry) {
          const totalPeserta = (gEntry?.peserta || 0) + (sEntry?.peserta || 0);
          methodValEl.textContent = `${totalPeserta} Peserta Pelatihan`;
        } else {
          methodValEl.textContent = 'GASING Hore';
        }
      }
      
      this.tooltip.classList.remove('opacity-0', 'pointer-events-none');
      this.tooltip.classList.add('opacity-100');
    }

    moveTooltip(e) {
      if (!this.tooltip) return;
      
      // Calculate position relative to container
      const rect = this.canvasContainer.getBoundingClientRect();
      const x = e.clientX - rect.left + 15;
      const y = e.clientY - rect.top + 15;
      
      this.tooltip.style.left = `${x}px`;
      this.tooltip.style.top = `${y}px`;
    }

    hideTooltip() {
      if (!this.tooltip) return;
      this.tooltip.classList.remove('opacity-100');
      this.tooltip.classList.add('opacity-0', 'pointer-events-none');
    }

    playVideo(videoId, name) {
      if (!this.modal || !this.iframe) return;
      
      this.modal.querySelector('.modal-title').textContent = `Pelatihan GASING di Kab. ${name}`;
      this.iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
      
      this.currentKabName = name;
      this.currentActiveTab = 'guru';
      
      this.renderModalStats();
      
      this.modal.classList.remove('pointer-events-none', 'opacity-0');
      this.modal.classList.add('opacity-100');
    }

    renderModalStats() {
      const chartCanvas = document.getElementById('grafana-chart-canvas');
      const pesertaCount = document.getElementById('stats-peserta-count');
      if (!chartCanvas || !pesertaCount) return;
      
      const { gEntry, sEntry } = this.findStats(this.currentKabName);
      const entry = this.currentActiveTab === 'guru' ? gEntry : sEntry;
      
      // Handle tab button visual states
      const tabGuru = document.getElementById('btn-tab-guru');
      const tabSiswa = document.getElementById('btn-tab-siswa');
      if (tabGuru && tabSiswa) {
        tabGuru.classList.toggle('active', this.currentActiveTab === 'guru');
        tabSiswa.classList.toggle('active', this.currentActiveTab === 'siswa');
      }
      
      if (!entry) {
        pesertaCount.textContent = '0';
        chartCanvas.innerHTML = '<div style="text-align: center; color: rgba(255, 255, 255, 0.2); font-size: 0.75rem; padding: 60px 0; font-family: Inter, sans-serif;">Data statistik tidak tersedia untuk wilayah ini</div>';
        return;
      }
      
      pesertaCount.textContent = entry.peserta.toLocaleString('id-ID');
      
      // Reordered per GASING teaching steps: Tambah, Kali, Kurang, Bagi, BAKALKUBAGI
      const metrics = [
        { label: 'Penjumlahan', code: '➕ Tambah', pre: entry.penjumlahanPre, post: entry.penjumlahanPost },
        { label: 'Perkalian', code: '✖️ Kali', pre: entry.perkalianPre, post: entry.perkalianPost },
        { label: 'Pengurangan', code: '➖ Kurang', pre: entry.penguranganPre, post: entry.penguranganPost },
        { label: 'Pembagian', code: '➗ Bagi', pre: entry.pembagianPre, post: entry.pembagianPost },
        { label: 'BakalKubagi', code: '🎯 BAKALKUBAGI', pre: entry.bakalkubagiPre, post: entry.bakalkubagiPost }
      ];

      // ─── Draw SVG Grafana Graph ───
      const valToY = (val) => 180 - (val * 1.4); // Maps 0-100 to Y coordinates 180 to 40
      
      let svgHtml = `
        <svg viewBox="0 0 500 220" class="w-full h-auto" style="overflow: visible;">
          <!-- SVG Internal Legend (Wider gaps to prevent overlaps: X = 60, 200, 340) -->
          <g transform="translate(60, 12)">
            <!-- Pre-test Legend -->
            <rect x="0" y="0" width="8" height="8" fill="#ff780a" rx="1.5" />
            <text x="12" y="8" fill="#9fa7ad" font-size="8.5" font-family="Inter, sans-serif">Pre-test (Nilai)</text>
            
            <!-- Post-test Legend -->
            <rect x="140" y="0" width="8" height="8" fill="#73bf69" rx="1.5" />
            <text x="152" y="8" fill="#9fa7ad" font-size="8.5" font-family="Inter, sans-serif">Post-test (Nilai)</text>
            
            <!-- Delta/Increase Legend -->
            <text x="280" y="8" fill="#fbbf24" font-size="8.5" font-family="Inter, sans-serif" font-weight="700">↑ Kenaikan (%)</text>
          </g>

          <!-- Y-Axis Gridlines -->
          <line x1="45" y1="40" x2="480" y2="40" stroke="#2c3235" stroke-dasharray="2 2" />
          <text x="36" y="43" fill="#9fa7ad" font-size="9" text-anchor="end" font-family="monospace">100</text>
          
          <line x1="45" y1="75" x2="480" y2="75" stroke="#2c3235" stroke-dasharray="2 2" />
          <text x="36" y="78" fill="#9fa7ad" font-size="9" text-anchor="end" font-family="monospace">75</text>
          
          <line x1="45" y1="110" x2="480" y2="110" stroke="#2c3235" stroke-dasharray="2 2" />
          <text x="36" y="113" fill="#9fa7ad" font-size="9" text-anchor="end" font-family="monospace">50</text>
          
          <line x1="45" y1="145" x2="480" y2="145" stroke="#2c3235" stroke-dasharray="2 2" />
          <text x="36" y="148" fill="#9fa7ad" font-size="9" text-anchor="end" font-family="monospace">25</text>
          
          <line x1="45" y1="180" x2="480" y2="180" stroke="#4f5d65" stroke-width="1.5" />
          <text x="36" y="183" fill="#9fa7ad" font-size="9" text-anchor="end" font-family="monospace">0</text>
      `;

      if (this.currentChartType === 'bar') {
        // --- Bar Chart Render ---
        metrics.forEach((m, idx) => {
          const x = 85 + idx * 86;
          const preY = valToY(m.pre);
          const postY = valToY(m.post);
          
          const delta = m.pre > 0 ? (((m.post - m.pre) / m.pre) * 100) : 0;
          let deltaColor = '#ef4444';
          if (delta >= 40) deltaColor = '#73bf69';
          else if (delta >= 20) deltaColor = '#eca938';
          
          // Arch parameters for growth indicator
          const preCenterX = x - 10;
          const postCenterX = x + 10;
          const controlY = Math.min(preY, postY) - 16;

          // Pre Bar (Orange - plain number)
          svgHtml += `
            <rect x="${x - 18}" y="${preY}" width="16" height="${180 - preY}" fill="#ff780a" rx="1" />
            <text x="${x - 10}" y="${preY - 4}" fill="#ff780a" font-size="8" font-family="monospace" text-anchor="middle" font-weight="700">${m.pre.toFixed(0)}</text>
          `;
          
          // Post Bar (Green - plain number)
          svgHtml += `
            <rect x="${x + 2}" y="${postY}" width="16" height="${180 - postY}" fill="#73bf69" rx="1" />
            <text x="${x + 10}" y="${postY - 4}" fill="#73bf69" font-size="8" font-family="monospace" text-anchor="middle" font-weight="700">${m.post.toFixed(0)}</text>
          `;
          
          // McKinsey-style Bezier Curve connector for delta growth
          svgHtml += `
            <path d="M ${preCenterX} ${preY} Q ${x} ${controlY} ${postCenterX} ${postY}" 
                  stroke="${deltaColor}" stroke-width="1.2" stroke-dasharray="2 2" fill="none" />
            <text x="${x}" y="${controlY - 4}" fill="${deltaColor}" font-size="8" font-family="monospace" text-anchor="middle" font-weight="900">+${delta.toFixed(0)}%</text>
          `;

          // X-Axis Column Name (Slightly smaller font size to fit long BAKALKUBAGI text)
          svgHtml += `
            <text x="${x}" y="200" fill="#c7d2d6" font-size="7.5" font-weight="700" text-anchor="middle" font-family="Inter, sans-serif">${m.code}</text>
          `;
        });
      } else {
        // --- Line Chart Render ---
        let prePoints = [];
        let postPoints = [];
        metrics.forEach((m, idx) => {
          const x = 85 + idx * 86;
          const preY = valToY(m.pre);
          const postY = valToY(m.post);
          prePoints.push({ x, y: preY, val: m.pre });
          postPoints.push({ x, y: postY, val: m.post });
        });

        // Pre area & line
        let prePath = `M ${prePoints[0].x} ${prePoints[0].y}`;
        for (let i = 1; i < prePoints.length; i++) {
          prePath += ` L ${prePoints[i].x} ${prePoints[i].y}`;
        }
        const preAreaPath = `${prePath} L ${prePoints[prePoints.length - 1].x} 180 L ${prePoints[0].x} 180 Z`;
        svgHtml += `<path d="${preAreaPath}" fill="rgba(255, 120, 10, 0.12)" />`;
        svgHtml += `<path d="${prePath}" stroke="#ff780a" stroke-width="2.5" fill="none" stroke-linejoin="round" />`;

        // Post area & line
        let postPath = `M ${postPoints[0].x} ${postPoints[0].y}`;
        for (let i = 1; i < postPoints.length; i++) {
          postPath += ` L ${postPoints[i].x} ${postPoints[i].y}`;
        }
        const postAreaPath = `${postPath} L ${postPoints[postPoints.length - 1].x} 180 L ${postPoints[0].x} 180 Z`;
        svgHtml += `<path d="${postAreaPath}" fill="rgba(115, 191, 105, 0.12)" />`;
        svgHtml += `<path d="${postPath}" stroke="#73bf69" stroke-width="2.5" fill="none" stroke-linejoin="round" stroke-linecap="round" stroke-linecap="round" />`;

        // Draw points & growth vertical dashed lines
        metrics.forEach((m, idx) => {
          const x = 85 + idx * 86;
          const prePt = prePoints[idx];
          const postPt = postPoints[idx];
          
          const delta = m.pre > 0 ? (((m.post - m.pre) / m.pre) * 100) : 0;
          let deltaColor = '#ef4444';
          if (delta >= 40) deltaColor = '#73bf69';
          else if (delta >= 20) deltaColor = '#eca938';
          
          // Vertical growth connector line with middle badge
          svgHtml += `
            <line x1="${x}" y1="${prePt.y}" x2="${x}" y2="${postPt.y}" stroke="${deltaColor}" stroke-dasharray="2 2" stroke-width="1.2" />
          `;

          // Pre Point Dot & label
          svgHtml += `
            <circle cx="${prePt.x}" cy="${prePt.y}" r="4" fill="#ff780a" stroke="#181b1f" stroke-width="1.5" />
            <text x="${prePt.x}" y="${prePt.y - 6}" fill="#ff780a" font-size="8" font-family="monospace" text-anchor="middle" font-weight="700">${prePt.val.toFixed(0)}</text>
          `;

          // Post Point Dot & label
          svgHtml += `
            <circle cx="${postPt.x}" cy="${postPt.y}" r="4" fill="#73bf69" stroke="#181b1f" stroke-width="1.5" />
            <text x="${postPt.x}" y="${postPt.y - 6}" fill="#73bf69" font-size="8" font-family="monospace" text-anchor="middle" font-weight="700">${postPt.val.toFixed(0)}</text>
          `;

          // Masked mid-way delta growth pill
          const midY = (prePt.y + postPt.y) / 2;
          svgHtml += `
            <rect x="${x - 16}" y="${midY - 6}" width="32" height="12" fill="#181b1f" rx="2" />
            <text x="${x}" y="${midY + 3}" fill="${deltaColor}" font-size="8" font-family="monospace" text-anchor="middle" font-weight="900">+${delta.toFixed(0)}%</text>
          `;
        });

        // Draw X-axis names (Slightly smaller font size to fit long BAKALKUBAGI text)
        metrics.forEach((m, idx) => {
          const x = 85 + idx * 86;
          svgHtml += `
            <text x="${x}" y="200" fill="#c7d2d6" font-size="7.5" font-weight="700" text-anchor="middle" font-family="Inter, sans-serif">${m.code}</text>
          `;
        });
      }

      svgHtml += `</svg>`;
      chartCanvas.innerHTML = svgHtml;
    }

    setupModalEvents() {
      if (this.modalClose) {
        this.modalClose.addEventListener('click', () => this.closeModal());
      }
      if (this.modal) {
        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) this.closeModal();
        });
      }
      
      // Tab switcher clicks
      const tabGuru = document.getElementById('btn-tab-guru');
      const tabSiswa = document.getElementById('btn-tab-siswa');
      if (tabGuru) {
        tabGuru.addEventListener('click', () => {
          this.currentActiveTab = 'guru';
          this.renderModalStats();
        });
      }
      if (tabSiswa) {
        tabSiswa.addEventListener('click', () => {
          this.currentActiveTab = 'siswa';
          this.renderModalStats();
        });
      }

      // Chart type switcher clicks
      const btnBar = document.getElementById('btn-chart-bar');
      const btnLine = document.getElementById('btn-chart-line');
      if (btnBar) {
        btnBar.addEventListener('click', () => {
          this.currentChartType = 'bar';
          btnBar.classList.add('active');
          if (btnLine) btnLine.classList.remove('active');
          this.renderModalStats();
        });
      }
      if (btnLine) {
        btnLine.addEventListener('click', () => {
          this.currentChartType = 'line';
          btnLine.classList.add('active');
          if (btnBar) btnBar.classList.remove('active');
          this.renderModalStats();
        });
      }
    }

    closeModal() {
      if (!this.modal || !this.iframe) return;
      this.modal.classList.add('pointer-events-none', 'opacity-0');
      this.modal.classList.remove('opacity-100');
      this.iframe.src = ''; // Stop video playback
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', () => {
    const mapCard = document.querySelector('.map-card');
    if (mapCard) {
      new InteractiveMap(mapCard);
    }
  });
</script>

<style>
  .map-card {
    padding: 32px;
    border-radius: var(--border-radius-lg);
