<div class="map-card glass-panel">
  <div class="map-header">
    <h3>🗺️ Peta Dampak Pelatihan GASING Nusantara</h3>
    <p>Sentuh atau klik titik pada peta untuk melihat bukti nyata perubahan numerasi anak-anak bangsa di daerah tersebut.</p>
  </div>

  <div class="map-layout-grid">
    <!-- Left Pane: Map and Legend -->
    <div class="map-left-pane">
      <div class="map-canvas-container relative">
        <div class="map-loading">
          <div class="spinner"></div>
          <p>Memuat Peta Nusantara...</p>
        </div>
        <!-- SVG Indonesia Map will be injected dynamically here -->
      </div>

      <div class="map-legend">
        <div class="legend-item">
          <span class="legend-dot active-dot"></span>
          <span>127+ Wilayah Sukses Terintervensi</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot waiting-dot"></span>
          <span>387 Wilayah Menunggu Dukungan Anda</span>
        </div>
      </div>
    </div>

    <!-- Right Pane: Scrollable List of Provinces/Kabupatens with Search Filter -->
    <div class="map-right-pane glass-panel">
      <div class="list-search-box">
        <input type="text" id="map-search-input" placeholder="🔍 Cari Kabupaten atau Provinsi..." class="map-search-input" />
      </div>
      <div class="map-regions-list" id="map-regions-list">
        <!-- List items will be injected dynamically -->
      </div>
    </div>
  </div>

  <!-- Unified Stats Dashboard -->
  <div class="national-stats-dashboard glass-panel mt-8 p-6" id="national-dashboard">
    <div class="flex justify-between items-center mb-6 flex-wrap gap-4">
      <div>
        <h4 class="font-serif text-gold flex items-center gap-2 mb-1" id="dashboard-title" style="margin: 0;">
          📈 Rata-Rata Hasil Pretest & Posttest Nasional
        </h4>
        <p class="text-xs text-muted" id="dashboard-subtitle" style="margin: 0;">
          Peningkatan kompetensi numerasi di 127 Kabupaten/Kota yang telah sukses terintervensi metode GASING.
        </p>
      </div>
      
      <!-- Actions Container (Reset Button & Tabs) -->
      <div class="flex gap-2 items-center flex-wrap">
        <button class="dashboard-reset-btn hidden" id="btn-dash-reset" style="margin-right: 8px;">🔄 Kembali ke Nasional</button>
        <div class="flex gap-2">
          <button class="dashboard-tab-btn active" id="btn-dash-guru">👨‍🏫 Rata-rata Guru</button>
          <button class="dashboard-tab-btn" id="btn-dash-siswa">👨‍🎓 Rata-rata Siswa</button>
        </div>
