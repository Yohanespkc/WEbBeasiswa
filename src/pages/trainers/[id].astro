---
import Layout from '../../layouts/Layout.astro';

// Force SSR for request-time dynamic database queries
export const prerender = false;

interface Trainer {
  id: number;
  name: string;
  photo_url: string;
  major: string;
  university: string;
  bio: string;
  story_emotional: string;
  home_regency: string;
  home_province: string;
  target_funding: number;
  current_funding: number;
  is_funded: number;
  password?: string;
  gasing_testimony?: string;
  gpa: number;
}

const { id } = Astro.params;
let trainer: Trainer | null = null;
let dbError = "";

import { env } from 'cloudflare:workers';

try {
  if (env && env.DB) {
    const result = await env.DB.prepare("SELECT * FROM trainers WHERE id = ?").bind(Number(id)).first();
    trainer = result as unknown as Trainer;
  } else {
    dbError = "Database D1 tidak terdeteksi.";
  }
} catch (err: any) {
  console.error("Database query error:", err);
  dbError = `Gagal memuat data trainer: ${err.message}`;
}

// Redirect if not found
if (!trainer && !dbError) {
  return Astro.redirect('/trainers');
}

const percent = trainer ? Math.min(100, Math.round((trainer.current_funding / trainer.target_funding) * 100)) : 0;

import { KABUPATEN_DATA } from '../../data/statistikRegistry';
let regencyStats: any = null;
if (trainer) {
  const cleanRegencyName = (name: string) => name.toLowerCase().replace(/kabupaten\s+|kab\.\s+|kota\s+/g, "").trim();
  const regencyName = cleanRegencyName(trainer.home_regency);
  regencyStats = KABUPATEN_DATA.find(d => cleanRegencyName(d.kabupaten) === regencyName);
}
---

<Layout title={trainer ? `Profil ${trainer.name}` : "Profil Trainer"} description={trainer ? trainer.bio : "Detail profil calon penerima beasiswa."}>
  <section class="section-padding">
    <div class="container">
      
      {dbError && (
        <div class="error-banner glass-panel">
          <p>⚠️ {dbError}</p>
        </div>
      )}

      {trainer && (
        <div class="trainer-details-grid">
          <!-- Left Column: Media & Story (Details View Container) -->
          <div class="details-left" id="details-view-container">
            <div class="glass-panel profile-hero-card">
              <div class="profile-image-container">
                <img src={trainer.photo_url} alt={trainer.name} class="profile-image" id="view-profile-image" />
                {trainer.is_funded === 1 && (
                  <span class="funded-badge">🎉 Didanai Penuh</span>
                )}
              </div>
              <div class="profile-meta p-6">
                <span class="loc-text" id="view-loc-text">{trainer.home_regency}, {trainer.home_province}</span>
                <h2 id="view-name-text">{trainer.name} <span class="text-xs text-gold/80 font-normal ml-1" id="view-gpa-text">(IPK {trainer.gpa ? trainer.gpa.toFixed(2).replace('.', ',') : '0,00'})</span></h2>
                <h4 class="major-text text-gold" id="view-major-text">{trainer.major}</h4>
                <p class="univ-text text-sm text-muted mb-4" id="view-univ-text">{trainer.university}</p>
                
                <!-- Open Edit Mode Button -->
                <button class="btn btn-secondary text-xs" id="open-edit-mode-btn">✏️ Edit Profil</button>
              </div>
            </div>

            <!-- Emotional Story Card with scrollbar support -->
            <div class="glass-panel story-card mt-6 p-6">
              <h3 class="section-title text-gold font-serif">📖 Kisah Perjuangan di Pelosok</h3>
              <div class="story-scroll-box mt-3">
                <p class="story-content leading-relaxed text-justify" id="view-story-text">{trainer.story_emotional}</p>
              </div>
            </div>

            <!-- Testimony Card with scrollbar support -->
            <div class="glass-panel testimony-card mt-6 p-6">
              <h3 class="section-title text-emerald-400 font-serif">✨ Testimoni: GASING Mengubahku</h3>
              <div class="story-scroll-box mt-3">
                <p class="story-content leading-relaxed text-justify italic" id="view-testimony-text">{trainer.gasing_testimony || "Testimoni belum diisi."}</p>
              </div>
            </div>

            {regencyStats && (
              <div class="glass-panel stats-card mt-6 p-6">
                <h3 class="section-title text-gold font-serif flex items-center gap-2">
                  📊 Dampak Pelatihan GASING di {trainer.home_regency}
                </h3>
                <p class="text-xs text-muted mt-1 mb-6">
                  Data statistik peningkatan kemampuan guru sebelum (Pre) dan sesudah (Post) dilatih menggunakan metode GASING:
                </p>

                <div class="metrics-comparison flex flex-col gap-4">
                  <div>
                    <div class="flex justify-between text-xs mb-1 font-semibold text-white">
                      <span>Penjumlahan (Addition)</span>
                      <span>Pre: {regencyStats.penjumlahanPre}% → Post: {regencyStats.penjumlahanPost}%</span>
                    </div>
                    <div class="stat-bar-wrapper flex gap-1 h-3 rounded overflow-hidden bg-white/5">
                      <div class="bg-amber-600/60" style={`width: ${regencyStats.penjumlahanPre}%;`} title="Pre-Test"></div>
                      <div class="bg-emerald-500 shimmer-bar" style={`width: ${regencyStats.penjumlahanPost - regencyStats.penjumlahanPre}%;`} title="Peningkatan"></div>
                    </div>
                  </div>

                  <div>
                    <div class="flex justify-between text-xs mb-1 font-semibold text-white">
                      <span>Pengurangan (Subtraction)</span>
                      <span>Pre: {regencyStats.penguranganPre}% → Post: {regencyStats.penguranganPost}%</span>
                    </div>
                    <div class="stat-bar-wrapper flex gap-1 h-3 rounded overflow-hidden bg-white/5">
                      <div class="bg-amber-600/60" style={`width: ${regencyStats.penguranganPre}%;`} title="Pre-Test"></div>
                      <div class="bg-emerald-500 shimmer-bar" style={`width: ${regencyStats.penguranganPost - regencyStats.penguranganPre}%;`} title="Peningkatan"></div>
                    </div>
                  </div>

                  <div>
                    <div class="flex justify-between text-xs mb-1 font-semibold text-white">
                      <span>Perkalian (Multiplication)</span>
                      <span>Pre: {regencyStats.perkalianPre}% → Post: {regencyStats.perkalianPost}%</span>
                    </div>
                    <div class="stat-bar-wrapper flex gap-1 h-3 rounded overflow-hidden bg-white/5">
                      <div class="bg-amber-600/60" style={`width: ${regencyStats.perkalianPre}%;`} title="Pre-Test"></div>
                      <div class="bg-emerald-500 shimmer-bar" style={`width: ${regencyStats.perkalianPost - regencyStats.perkalianPre}%;`} title="Peningkatan"></div>
                    </div>
                  </div>

                  <div>
                    <div class="flex justify-between text-xs mb-1 font-semibold text-white">
                      <span>Pembagian (Division)</span>
                      <span>Pre: {regencyStats.pembagianPre}% → Post: {regencyStats.pembagianPost}%</span>
                    </div>
                    <div class="stat-bar-wrapper flex gap-1 h-3 rounded overflow-hidden bg-white/5">
                      <div class="bg-amber-600/60" style={`width: ${regencyStats.pembagianPre}%;`} title="Pre-Test"></div>
                      <div class="bg-emerald-500 shimmer-bar" style={`width: ${regencyStats.pembagianPost - regencyStats.pembagianPre}%;`} title="Peningkatan"></div>
                    </div>
                  </div>
                </div>
                
                <p class="text-[10px] text-muted mt-4 italic text-center">
                  *Rasio rata-rata peningkatan kemampuan numerasi: <strong>{regencyStats.rasio.toFixed(2)}x lebih cepat</strong>
                </p>
              </div>
            )}
          </div>

          <!-- Left Column: Profile Editor Form (Hidden by Default) -->
          <div class="details-left hidden" id="details-edit-container">
            <div class="glass-panel p-6">
              <h3 class="font-serif text-gold mb-6">✏️ Edit Profil Penerima Beasiswa</h3>
              
              <form id="edit-trainer-form">
                <div class="form-group mb-4">
                  <label class="form-label text-xs uppercase text-muted block mb-1">Nama Lengkap</label>
                  <input type="text" id="edit-name" class="form-control" value={trainer.name} required />
                </div>
                
                <div class="form-group mb-4">
                  <label class="form-label text-xs uppercase text-muted block mb-1">Foto Profil</label>
                  <div class="flex gap-4 items-center flex-wrap md:flex-nowrap">
                    <img src={trainer.photo_url} alt="Pratinjau" class="w-16 h-16 object-cover rounded border border-white/10" id="edit-photo-preview" />
                    <div class="flex-1">
                      <input type="file" id="edit-photo-file" accept="image/*" class="form-control text-xs" />
                      <p class="text-[10px] text-muted mt-1">Atau gunakan URL gambar langsung:</p>
                      <input type="text" id="edit-photo-url" class="form-control text-xs mt-1" value={trainer.photo_url} />
                    </div>
                  </div>
                </div>

                <div class="gap-4 mb-4 grid-half">
                  <div class="form-group">
                    <label class="form-label text-xs uppercase text-muted block mb-1">Program Studi</label>
                    <input type="text" id="edit-major" class="form-control" value={trainer.major} required />
                  </div>
                  <div class="form-group">
                    <label class="form-label text-xs uppercase text-muted block mb-1">Universitas</label>
                    <input type="text" id="edit-university" class="form-control" value={trainer.university} required />
                  </div>
                </div>

                <div class="gap-4 mb-4 grid-half">
                  <div class="form-group">
                    <label class="form-label text-xs uppercase text-muted block mb-1">Kabupaten Asal</label>
                    <input type="text" id="edit-regency" class="form-control" value={trainer.home_regency} required />
                  </div>
                  <div class="form-group">
                    <label class="form-label text-xs uppercase text-muted block mb-1">Provinsi Asal</label>
                    <input type="text" id="edit-province" class="form-control" value={trainer.home_province} required />
                  </div>
                </div>

                <div class="form-group mb-4">
                  <label class="form-label text-xs uppercase text-muted block mb-1">Bio Singkat (Max 200 karakter)</label>
                  <textarea id="edit-bio" class="form-control text-sm" rows="3" required>{trainer.bio}</textarea>
                </div>

                <div class="form-group mb-6">
                  <label class="form-label text-xs uppercase text-muted block mb-1">Kisah Perjuangan (Lengkap)</label>
                  <textarea id="edit-story" class="form-control text-sm" rows="8" required>{trainer.story_emotional}</textarea>
                </div>

                <div class="form-group mb-6">
                  <label class="form-label text-xs uppercase text-muted block mb-1">Testimoni: GASING Mengubahku</label>
                  <textarea id="edit-testimony" class="form-control text-sm" rows="6" required>{trainer.gasing_testimony || ""}</textarea>
                </div>

                <div class="form-group mb-6">
                  <label class="form-label text-xs uppercase text-muted block mb-1">PIN / Sandi Edit Baru (4-digit)</label>
                  <input type="text" id="edit-password" class="form-control font-mono tracking-widest text-center mb-1" value={(trainer as any).password} maxlength="8" required />
                  <p class="text-[10px] text-muted italic">* PIN awal Anda adalah "1234". Demi keamanan, silakan ubah PIN Anda menjadi 4-digit sandi lainnya. Admin tetap dapat mengakses profil Anda jika diperlukan.</p>
                </div>

                <div class="flex gap-4">
                  <button type="button" class="btn btn-secondary flex-1" id="cancel-edit-btn">Batal</button>
                  <button type="submit" class="btn btn-primary flex-1">Simpan Perubahan</button>
                </div>
              </form>
            </div>
          </div>

          <!-- Right Column: Funding Status & Impact Calculator -->
          <div class="details-right">
            <!-- Funding Summary Card -->
            <div class="glass-panel funding-card p-6">
              <h3 class="font-serif mb-4 text-center">Dukungan Studi Berkelanjutan</h3>
              
              <div class="funding-stats flex justify-between text-center mb-6">
                <div>
                  <span class="lbl block text-[10px] uppercase text-muted tracking-wider">Terkumpul</span>
                  <span class="val text-lg font-bold text-success">Rp {Math.round(trainer.current_funding).toLocaleString('id-ID')}</span>
                </div>
                <div class="border-divider"></div>
                <div>
                  <span class="lbl block text-[10px] uppercase text-muted tracking-wider">Target Biaya</span>
                  <span class="val text-lg font-bold">Rp {trainer.target_funding.toLocaleString('id-ID')}</span>
                </div>
              </div>

              <div class="progress-container mb-6">
                <div class="flex justify-between text-xs mb-1">
                  <span>Progres Dukungan</span>
                  <span>{percent}%</span>
                </div>
                <div class="bar-bg">
                  <div class="bar-fill shimmer-bar" style={`width: ${percent}%;`}></div>
                </div>
              </div>

              <p class="text-xs text-muted leading-relaxed text-center italic">*Seluruh alokasi dukungan disalurkan langsung ke rekening rektorat universitas untuk menjamin kelancaran perkuliahan dan riset para trainer.</p>
            </div>

            <!-- Interactive Impact Calculator -->
            <div class="glass-panel calculator-card mt-6 p-6" id="impact-calculator">
              <h3 class="font-serif text-gold text-center mb-4">🧮 Simulasi Kontribusi Perubahan</h3>
              <p class="text-xs text-muted text-center mb-6">Geser slider untuk melihat bagaimana kontribusi Anda mempercepat penyelesaian studi S2/S3 dan memperluas dampak pengabdian para trainer.</p>
              
              <!-- Slider Input -->
              <div class="slider-wrapper">
                <input 
                  type="range" 
                  min="50000" 
                  max="10000000" 
                  step="50000" 
                  value="1000000" 
                  class="impact-slider" 
                  id="impact-slider"
                />
                <div class="flex justify-between text-[10px] text-muted mt-2">
                  <span>Rp 50.000</span>
                  <span>Rp 5.000.000</span>
                  <span>Rp 10.000.000+</span>
                </div>
              </div>

              <!-- Animated Impact Result Box -->
              <div class="impact-result-box glass-panel p-4 mt-6 text-center">
                <span class="lbl text-[10px] text-gold uppercase tracking-wider block">Simulasi Nilai Kontribusi</span>
                <span class="simulated-val text-xl font-bold block my-1" id="simulated-amount">Rp 1.000.000</span>
                <p class="impact-text text-sm leading-relaxed text-white mt-3" id="simulated-impact">
                  Membantu membiayai transport riset pengabdian numerasi {trainer.name} ke daerah 3T selama 1 Semester.
                </p>
              </div>

              <button class="btn btn-primary w-full text-center mt-6" id="donate-now-btn">
                Bergabung dalam Gotong Royong
              </button>
              <p class="text-[10px] text-muted text-center mt-2 italic">* Seluruh kontribusi dikelola melalui Dana Bersama dan disalurkan secara adil guna mendukung studi 80 trainer S2 di UPI & 2 trainer S2 di Columbia.</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Password Prompt Modal -->
  <div class="modal-overlay hidden" id="password-modal">
    <div class="modal-content glass-panel p-6 max-w-sm w-full relative">
      <h3 class="font-serif text-center mb-2">Autentikasi Profil</h3>
      <p class="text-xs text-muted text-center mb-6">Masukkan PIN 4-digit Anda (atau Sandi Master Admin) untuk mengedit profil ini.</p>
      
      <div class="form-group mb-6">
        <input 
          type="password" 
          id="auth-pin-input" 
          placeholder="Masukkan PIN / Sandi..." 
          class="form-control text-center text-lg tracking-widest font-mono" 
          maxlength="8" 
          required 
        />
        <p class="text-danger text-xs text-center mt-2 hidden" id="auth-error-msg">PIN salah. Silakan coba lagi.</p>
      </div>

      <div class="flex gap-4">
        <button class="btn btn-secondary flex-1" id="close-password-btn">Batal</button>
        <button class="btn btn-primary flex-1" id="confirm-password-btn">Konfirmasi</button>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ trainerId: id, trainerName: trainer?.name || "" }}>
  document.addEventListener('DOMContentLoaded', () => {
    // --- Funding slider logic ---
    const slider = document.getElementById('impact-slider');
    const displayAmount = document.getElementById('simulated-amount');
    const displayImpact = document.getElementById('simulated-impact');
    const donateBtn = document.getElementById('donate-now-btn');

    if (slider && displayAmount && displayImpact && donateBtn) {
      const updateImpact = (val) => {
        const amount = Number(val);
        displayAmount.textContent = `Rp ${amount.toLocaleString('id-ID')}`;

        if (amount < 250000) {
          displayImpact.textContent = `Membantu menanggung paket modul buku pegangan matematika GASING dan alat peraga manipulatif konkret untuk studi para asisten trainer.`;
        } else if (amount >= 250000 && amount < 1000000) {
          displayImpact.textContent = `Membantu menutupi biaya internet kuota data kuliah daring dan buku referensi wajib untuk mendukung tesis para asisten trainer.`;
        } else if (amount >= 1000000 && amount < 4000000) {
          displayImpact.textContent = `Membantu membiayai transport tiket pesawat riset/pengabdian numerasi para asisten trainer ke sekolah-sekolah di pelosok daerah asal.`;
        } else if (amount >= 4000000 && amount < 8000000) {
          displayImpact.textContent = `Membantu membiayai sewa tempat tinggal (kos) dan tunjangan hidup bulanan para asisten trainer di sekitar kampus selama 1 Semester perkuliahan.`;
        } else {
          displayImpact.textContent = `Luar Biasa! Kontribusi Anda akan langsung memotong/melunasi biaya Sumbangan Pembinaan Pendidikan (SPP) Kuliah Semester para asisten trainer secara signifikan.`;
        }
      };

      slider.addEventListener('input', (e) => {
        updateImpact(e.target.value);
      });

      donateBtn.addEventListener('click', () => {
        const finalAmount = slider.value;
        window.location.href = `/donasi?trainerId=${trainerId}&amount=${finalAmount}`;
      });

      updateImpact(slider.value);
    }

    // --- Profile Editing logic ---
    const openEditBtn = document.getElementById('open-edit-mode-btn');
    const cancelEditBtn = document.getElementById('cancel-edit-btn');
    const modalOverlay = document.getElementById('password-modal');
    const closePasswordBtn = document.getElementById('close-password-btn');
    const confirmPasswordBtn = document.getElementById('confirm-password-btn');
    const pinInput = document.getElementById('auth-pin-input');
    const errorMsg = document.getElementById('auth-error-msg');
    
    const viewContainer = document.getElementById('details-view-container');
    const editContainer = document.getElementById('details-edit-container');
    const editForm = document.getElementById('edit-trainer-form');

    const photoFileInput = document.getElementById('edit-photo-file');
    const photoUrlInput = document.getElementById('edit-photo-url');
    const photoPreviewImg = document.getElementById('edit-photo-preview');

    let verifiedPassword = '';

    // URL Auth parameter auto-bypass
    const urlParams = new URLSearchParams(window.location.search);
    const authParam = urlParams.get('auth');
    const editParam = urlParams.get('edit');

    if (editParam === 'true' && authParam) {
      pinInput.value = authParam;
      handlePinVerification(authParam);
    }

    if (openEditBtn) {
      openEditBtn.addEventListener('click', () => {
        errorMsg.classList.add('hidden');
        pinInput.value = '';
        modalOverlay.classList.remove('hidden');
        setTimeout(() => modalOverlay.classList.add('show'), 10);
        pinInput.focus();
      });
    }

    if (closePasswordBtn) {
      closePasswordBtn.addEventListener('click', () => {
        modalOverlay.classList.remove('show');
        setTimeout(() => modalOverlay.classList.add('hidden'), 300);
      });
    }

    if (confirmPasswordBtn) {
      confirmPasswordBtn.addEventListener('click', () => {
        handlePinVerification(pinInput.value);
      });
    }

    if (pinInput) {
      pinInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          handlePinVerification(pinInput.value);
        }
      });
    }

    if (cancelEditBtn) {
      cancelEditBtn.addEventListener('click', () => {
        editContainer.classList.add('hidden');
        viewContainer.classList.remove('hidden');
        // Clean URL params if they were preset
        if (window.location.search) {
          window.history.replaceState({}, document.title, window.location.pathname);
        }
      });
    }

    // Photo File to Base64 FileReader binding
    if (photoFileInput && photoPreviewImg && photoUrlInput) {
      photoFileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (event) => {
            photoPreviewImg.src = event.target.result;
            photoUrlInput.value = event.target.result;
          };
          reader.readAsDataURL(file);
        }
      });

      photoUrlInput.addEventListener('input', (e) => {
        photoPreviewImg.src = e.target.value;
      });
    }

    async function handlePinVerification(pin) {
      if (!pin) return;
      try {
        errorMsg.classList.add('hidden');
        const res = await fetch('/api/update-trainer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: Number(trainerId),
            password: pin,
            name: trainerName // dummy verification run
          })
        });

        if (res.ok) {
          verifiedPassword = pin;
          modalOverlay.classList.remove('show');
          setTimeout(() => modalOverlay.classList.add('hidden'), 300);
          
          viewContainer.classList.add('hidden');
          editContainer.classList.remove('hidden');
        } else {
          const data = await res.json();
          errorMsg.textContent = data.error || 'PIN yang Anda masukkan salah.';
          errorMsg.classList.remove('hidden');
        }
      } catch (err) {
        console.error(err);
        errorMsg.textContent = 'Koneksi error. Silakan coba lagi.';
        errorMsg.classList.remove('hidden');
      }
    }

    // Form submission
    if (editForm) {
      editForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const payload = {
          id: Number(trainerId),
          password: verifiedPassword,
          new_password: document.getElementById('edit-password').value,
          name: document.getElementById('edit-name').value,
          photo_url: photoUrlInput.value,
          major: document.getElementById('edit-major').value,
          university: document.getElementById('edit-university').value,
          bio: document.getElementById('edit-bio').value,
          story_emotional: document.getElementById('edit-story').value,
          gasing_testimony: document.getElementById('edit-testimony').value,
          home_regency: document.getElementById('edit-regency').value,
          home_province: document.getElementById('edit-province').value,
        };

        try {
          const btnSubmit = editForm.querySelector('button[type="submit"]');
          const oldText = btnSubmit.textContent;
          btnSubmit.textContent = 'Menyimpan...';
          btnSubmit.disabled = true;

          const res = await fetch('/api/update-trainer', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (res.ok) {
            window.location.href = `/trainers/${trainerId}`;
          } else {
            const data = await res.json();
            alert(`Gagal menyimpan perubahan: ${data.error}`);
            btnSubmit.textContent = oldText;
            btnSubmit.disabled = false;
          }
        } catch (err) {
          alert(`Terjadi kesalahan: ${err.message}`);
        }
      });
    }
  });
</script>

<style>
  .trainer-details-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 992px) {
    .trainer-details-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .profile-hero-card {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }

  .profile-image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1.3;
    overflow: hidden;
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .funded-badge {
