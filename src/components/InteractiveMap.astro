  <div class="map-legend">
    <div class="legend-item">
      <span class="legend-dot active-dot"></span>
      <span>127+ Wilayah Sukses Terintervensi</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot waiting-dot"></span>
      <span>387 Wilayah Menunggu Dukungan Anda</span>
