---
import Layout from '../layouts/Layout.astro';
import { TOTAL_NEED_UPI } from '../data/constants';

// Force SSR for dynamic query
export const prerender = false;

interface DonationRecord {
  donor_name: string;
  amount: number;
  message: string | null;
  created_at: string;
}

let totalRaised = 0;
let donorCount = 0;
let donorWall: DonationRecord[] = [];
let dbError = "";

import { env } from 'cloudflare:workers';

try {
  if (env && env.DB) {
    // 1. Get total funds raised (excluding initial institutional sponsors to avoid double counting)
    const totalResult = await env.DB.prepare(
      "SELECT SUM(amount) as total FROM donations WHERE payment_status = 'settlement' AND donor_name NOT LIKE '%Test Donor%' AND id NOT IN ('GRAB-2025', 'ANONIM-2025')"
    ).first() as any;
    totalRaised = totalResult?.total || 0;

    // 2. Get donor count (excluding initial institutional sponsors)
    const countResult = await env.DB.prepare(
      "SELECT COUNT(*) as count FROM donations WHERE payment_status = 'settlement' AND donor_name NOT LIKE '%Test Donor%' AND id NOT IN ('GRAB-2025', 'ANONIM-2025')"
    ).first() as any;
    donorCount = countResult?.count || 0;

    // 3. Fetch successful donations for Donor Wall
    const { results } = await env.DB.prepare(
      `SELECT donor_name, amount, message, created_at 
       FROM donations 
       WHERE payment_status = 'settlement' AND donor_name NOT LIKE '%Test Donor%'
       ORDER BY created_at DESC 
       LIMIT 40`
    ).all();
    donorWall = results as unknown as DonationRecord[];

  } else {
    dbError = "Database D1 tidak terdeteksi.";
  }
} catch (err: any) {
  console.error("Database query error:", err);
  dbError = `Gagal memuat dashboard transparansi: ${err.message}`;
}

// Dynamic Calculations for Gotong Royong
const totalNeed = TOTAL_NEED_UPI;
const initialGrab = 1107290548;
const initialAnon = 1080000000;
const initialFunds = initialGrab + initialAnon; // 2187290548

// totalRaised holds public website donations
const currentDeficit = Math.max(0, totalNeed - (initialFunds + totalRaised));
const deficitPerPerson = Math.round(currentDeficit / 80);
const fundedPercentage = ((initialFunds + totalRaised) / totalNeed) * 100;
const fundedPercentageString = fundedPercentage.toFixed(1);
---

<Layout title="Transparansi & Dinding Donatur" description="Laporan transparansi alokasi dana 100% beasiswa dan daftar donatur publik yang mendukung para trainer GASING.">
  <section class="section-padding">
    <div class="container">
      
      <div class="transparency-header text-center mb-12">
        <span class="badge">🛡️ KEPATUHAN & TRANSPARANSI</span>
        <h2>Transparansi Keuangan & Dinding Donatur</h2>
        <p>Kami menjamin akuntabilitas setiap rupiah yang Anda donasikan. Semua dana publik disalurkan utuh 100% tanpa potongan.</p>
      </div>

      {dbError && (
        <div class="error-banner glass-panel mb-8">
          <p>⚠️ {dbError}</p>
        </div>
      )}

      <!-- Financial Dashboard Grid -->
      <div class="transparency-grid mb-12">
        <!-- Live Statistics Card -->
        <div class="glass-panel stat-summary-card p-8 flex flex-col justify-center text-center">
          <span class="lbl text-xs text-muted uppercase tracking-wider block mb-2">TOTAL DANA TERKUMPUL</span>
          <h1 class="total-funds text-success font-serif text-3xl md:text-4xl my-2">Rp {(initialFunds + totalRaised).toLocaleString('id-ID')}</h1>
          <p class="text-sm text-secondary mt-2">Dari total <strong>{donorCount} donatur</strong> luar biasa di seluruh Indonesia.</p>
          
          <div class="mt-6 pt-4 border-t border-white/10 flex justify-around text-xs text-muted">
            <div>
              <span>Rata-rata Terdistribusi:</span>
              <strong class="text-white block mt-1">Rp {Math.floor((initialFunds + totalRaised) / 80).toLocaleString('id-ID')} / AT</strong>
            </div>
            <div>
              <span>Biaya Operasional Platform:</span>
              <strong class="text-success block mt-1">0% (Tanpa Potongan)</strong>
            </div>
          </div>
        </div>

        <!-- Allocation Chart Card -->
        <div class="glass-panel allocation-card p-8">
          <h3 class="font-serif mb-4 text-center">Alokasi Penggunaan Dana</h3>
          
          <div class="allocation-bar-container flex mb-4">
            <div class="alloc-segment spp" style="width: 39%;" title="SPP Kuliah / Tuition Fee - 39%"></div>
            <div class="alloc-segment living" style="width: 46%;" title="Uang Saku / Living Allowance - 46%"></div>
            <div class="alloc-segment books" style="width: 15%;" title="Buku & Riset / Study Materials - 15%"></div>
          </div>

          <div class="allocation-legend text-xs flex flex-col gap-2">
            <div class="legend-row flex justify-between">
              <span class="flex items-center gap-2"><span class="legend-color spp-color"></span>SPP Kuliah (Tuition Fee)</span>
              <span><strong>39%</strong></span>
            </div>
            <div class="legend-row flex justify-between">
              <span class="flex items-center gap-2"><span class="legend-color living-color"></span>Biaya Hidup (Living Allowance)</span>
              <span><strong>46%</strong></span>
            </div>
            <div class="legend-row flex justify-between">
              <span class="flex items-center gap-2"><span class="legend-color books-color"></span>Buku, Modul & Riset Lapangan</span>
              <span><strong>15%</strong></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Detailed Budget breakdown card -->
      <div class="glass-panel budget-details-card p-8 mb-12 border border-amber-500/20">
        <h3 class="font-serif mb-6 text-center text-gold text-xl">📋 Perincian Anggaran Beasiswa</h3>
        
        <!-- Budget Status Overview (Funding Gap) -->
        <div class="funding-status-overview mb-8 p-4 rounded-xl bg-white/5 border border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
          <div class="w-full md:w-1/2">
            <span class="text-xs text-muted uppercase block mb-1">Status Pendanaan Program (UPI)</span>
            <div class="flex items-center gap-2">
              <span class="font-serif text-lg text-white font-bold">{fundedPercentageString}%</span>
              <span class="text-xs text-muted">Terkumpul dari kebutuhan Rp {(totalNeed / 1e9).toFixed(2).replace('.', ',')} Miliar</span>
            </div>
            <div class="w-full h-2 bg-white/10 rounded-full mt-2 overflow-hidden">
              <div class="h-full bg-success rounded-full" style={`width: ${fundedPercentage}%`}></div>
            </div>
          </div>
          <div class="flex gap-6 w-full md:w-auto justify-between md:justify-end">
            <div>
              <span class="text-[10px] text-muted block uppercase">Sisa Target Gotong Royong</span>
              <span class="text-red-400 font-bold text-sm block">Rp {currentDeficit.toLocaleString('id-ID')}</span>
            </div>
            <div>
              <span class="text-[10px] text-muted block uppercase">Kebutuhan per Orang</span>
              <span class="text-gold font-bold text-sm block">Rp {deficitPerPerson.toLocaleString('id-ID')}</span>
            </div>
          </div>
        </div>

        <div class="budget-details-grid text-sm leading-relaxed">
          <!-- UPI Budget Section -->
          <div class="upi-budget-column pr-6">
            <h4 class="font-sans font-bold text-primary mb-4 flex items-center gap-2 text-base">
              🎓 Program Magister UPI (80 Trainer)
            </h4>
            <table class="budget-table">
              <thead>
                <tr class="text-muted">
                  <th class="py-2 text-left text-xs uppercase tracking-wider font-semibold">Item Anggaran</th>
                  <th class="py-2 text-right text-xs uppercase tracking-wider font-semibold">Nominal (Rupiah)</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="py-2 font-semibold text-primary">Dana Awal Diterima Yayasan</td>
                  <td class="py-2 text-right font-semibold text-success">Rp 2.187.290.548</td>
                </tr>
                <tr class="text-muted">
                  <td class="pl-4 py-1 border-l-2 border-slate-200/60">Dana Dari Grab (30 Jul & 7 Okt 2025)</td>
                  <td class="py-1 text-right font-mono text-xs">Rp 1.107.290.548</td>
                </tr>
                <tr class="text-muted">
                  <td class="pl-4 py-1 border-l-2 border-slate-200/60">Dana Dari Anonim (Des 2025)</td>
                  <td class="py-1 text-right font-mono text-xs">Rp 1.080.000.000</td>
                </tr>
                
                <tr>
                  <td class="py-2 font-semibold text-primary">Kebutuhan Beasiswa 80 Mahasiswa</td>
                  <td class="py-2 text-right font-semibold text-gold">Rp {totalNeed.toLocaleString('id-ID')}</td>
                </tr>
                <tr class="text-muted">
                  <td class="pl-4 py-1 border-l-2 border-slate-200/60">Biaya Kuliah (Tuition Fee)</td>
                  <td class="py-1 text-right font-mono text-xs">Rp 7.312.000.000</td>
                </tr>
                <tr class="text-muted">
                  <td class="pl-4 py-1 border-l-2 border-slate-200/60">Biaya Hidup (Living Allowance)</td>
                  <td class="py-1 text-right font-mono text-xs">Rp 8.640.000.000</td>
                </tr>
                <tr class="text-muted">
                  <td class="pl-4 py-1 border-l-2 border-slate-200/60">Buku, Modul & Riset Lapangan</td>
                  <td class="py-1 text-right font-mono text-xs">Rp 2.815.058.824</td>
                </tr>
                
                <tr class="border-t border-slate-200/60">
                  <td class="py-2.5 font-bold text-primary">Sisa Target Gotong Royong</td>
                  <td class="py-2.5 text-right font-bold text-danger">Rp {currentDeficit.toLocaleString('id-ID')}</td>
                </tr>
              </tbody>
            </table>

            <div class="mt-4 p-4 rounded-xl border border-amber-500/20 bg-amber-500/5">
              <span class="text-[10px] text-gold font-bold uppercase tracking-wider block mb-1">🌱 Kebutuhan Sponsorship per Guru</span>
              <div class="flex justify-between items-baseline mb-2">
                <strong class="text-xl font-bold font-mono text-primary">Rp {deficitPerPerson.toLocaleString('id-ID')}</strong>
                <span class="text-xs text-secondary">/ 24 Bulan Studi</span>
              </div>
              <p class="text-xs text-secondary leading-relaxed">
                Sisa kebutuhan beasiswa UPI dikelola gotong royong secara transparan. Anda dapat mendanai sebagian dari biaya hidup atau SPP seorang guru (mulai dari nominal Rp 50.000) untuk meringankan beban gotong royong para trainer.
              </p>
            </div>
          </div>

          <!-- Columbia Budget Section (Featured Card) -->
          <div class="columbia-budget-column">
            <div class="glass-panel p-6 border border-amber-500/30 bg-amber-500/5 rounded-xl h-full flex flex-col justify-between">
              <div>
                <span class="badge mb-3" style="background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.3); color: var(--color-text-gold); margin-bottom: 8px;">🗽 COLUMBIA SPECIAL POOL</span>
                <h4 class="font-serif text-primary text-base mb-2">Program Khusus Columbia University</h4>
                <p class="text-[11px] text-secondary mb-4 leading-relaxed">
                  Program pendidikan khusus bagi 2 Asisten Trainer yang menempuh studi magister di Columbia University, New York, untuk perancangan kurikulum berstandar global.
                </p>
              </div>
              
              <div class="flex flex-col gap-3">
                <div class="bg-white/5 p-3 rounded-lg border border-slate-200/10">
                  <span class="block text-[10px] text-muted uppercase tracking-wider">Target Biaya per Trainer</span>
                  <strong class="text-gold text-base block mt-0.5 font-mono">$154.392 - $192.488 <span class="text-xs font-sans text-muted">USD</span></strong>
                  <span class="text-[9px] text-secondary block mt-0.5">Mencakup biaya kuliah penuh, riset, dan biaya hidup di New York City (16 - 24 bulan).</span>
                </div>
                
                <div class="bg-white/5 p-3 rounded-lg border border-slate-200/10">
                  <span class="block text-[10px] text-muted uppercase tracking-wider">Skema Pendanaan</span>
                  <strong class="text-primary text-xs block mt-0.5">Pendanaan Kemitraan Khusus</strong>
                  <span class="text-[9px] text-secondary block mt-0.5">Dana dicari khusus melalui kemitraan eksternal dan tidak memotong dana gotong royong UPI.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Vision Callout -->
      <div class="glass-panel p-6 mb-12 border border-success/20 bg-success/5 rounded-xl text-center">
        <p class="text-sm text-muted max-w-3xl mx-auto leading-relaxed">
          🌱 <strong>Visi Jangka Panjang:</strong> Program ini merupakan tahap awal dari inisiatif strategis mencetak <strong>1.000 Guru Doktor (Ph.D.)</strong>. Setelah menyelesaikan studi, para trainer akan kembali ke daerah pelosok Nusantara untuk mentransformasi kualitas pendidikan numerasi nasional secara gotong royong.
        </p>
      </div>

      <!-- Donor Wall (Dinding Donatur) -->
      <div class="donor-wall-container">
        <h3 class="font-serif text-center text-gold text-2xl mb-8">❤️ Dinding Donatur Kebajikan</h3>
        
        <div class="donor-wall-grid">
          {donorWall.length > 0 ? (
            donorWall.map((donor) => (
              <div class="glass-panel donor-card p-6 flex flex-col justify-between">
                <div>
                  <div class="donor-header flex justify-between items-start mb-3">
                    <h4 class="font-sans font-semibold text-white">{donor.donor_name}</h4>
                    <span class="donor-badge-amt">Rp {donor.amount.toLocaleString('id-ID')}</span>
                  </div>
                  {donor.message && (
                    <p class="donor-msg text-sm italic text-secondary leading-relaxed">
                      "{donor.message}"
                    </p>
                  )}
                </div>
                <div class="donor-footer text-[10px] text-muted mt-4 text-right">
                  {new Date(donor.created_at).toLocaleDateString('id-ID', {
                    day: 'numeric',
                    month: 'short',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                  })}
                </div>
              </div>
            ))
          ) : (
            !dbError && <p class="text-center text-muted col-span-3">Belum ada riwayat donatur sukses. Jadilah donatur pertama!</p>
          )}
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .transparency-header h2 {
    font-size: 2.2rem;
    margin-bottom: 8px;
  }

  .badge {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(10, 15, 30, 0.05);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 100px;
    color: var(--color-success);
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .transparency-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  @media (max-width: 768px) {
    .transparency-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .stat-summary-card {
    border-radius: var(--border-radius-lg);
    border-color: rgba(16, 185, 129, 0.15);
  }

  .total-funds {
    text-shadow: 0 0 15px rgba(16, 185, 129, 0.3);
  }

  .allocation-card {
    border-radius: var(--border-radius-lg);
  }

  /* Allocation Bar styling */
  .allocation-bar-container {
    height: 16px;
    border-radius: 100px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .alloc-segment {
    height: 100%;
    cursor: help;
    transition: opacity 0.2s ease;
  }

  .alloc-segment:hover {
    opacity: 0.85;
  }

  .spp {
    background-color: var(--color-accent-gold);
  }

  .living {
    background-color: var(--color-success);
  }

  .books {
    background-color: #3b82f6; /* Blue for materials */
  }

  .legend-color {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 3px;
  }

  .spp-color { background-color: var(--color-accent-gold); }
  .living-color { background-color: var(--color-success); }
  .books-color { background-color: #3b82f6; }

  /* Donor Wall card grid styling */
  .donor-wall-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 20px;
  }

  .col-span-3 {
    grid-column: span 3;
  }

  .donor-card {
    border-radius: var(--border-radius-md);
    min-height: 160px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .donor-badge-amt {
    padding: 4px 8px;
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.15);
    border-radius: 6px;
    color: var(--color-success);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .donor-msg {
    color: var(--color-text-secondary);
  }

  .text-gold {
    color: var(--color-text-gold);
  }

  .text-success {
    color: var(--color-success);
  }

  .error-banner {
    padding: 20px;
    color: var(--color-danger);
    background: rgba(239, 68, 68, 0.05);
    border-color: rgba(239, 68, 68, 0.2);
    border-radius: var(--border-radius-md);
    text-align: center;
  }

  /* Budget Details Scoped Styles */
  .budget-details-card {
    border-radius: var(--border-radius-lg);
    background: var(--color-bg-card);
  }

  .budget-details-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 32px;
  }

  @media (max-width: 768px) {
    .budget-details-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .upi-budget-column {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      padding-bottom: 24px;
    }
  }

  @media (min-width: 769px) {
    .upi-budget-column {
      border-right: 1px solid rgba(15, 23, 42, 0.08);
    }
  }

  .budget-table {
    width: 100%;
    border-collapse: collapse;
  }

  .budget-table th, .budget-table td {
    padding: 8px 0;
  }

  .budget-table th {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(15, 23, 42, 0.1);
  }

  .budget-table td {
    border-bottom: 1px solid rgba(15, 23, 42, 0.05);
  }

  .budget-table tr:last-child td {
    border-bottom: none;
  }

  /* Custom left border line to show indentation nesting */
  .border-l-2 {
    border-left-width: 2px;
  }
  .border-slate-200\/60 {
    border-color: rgba(71, 85, 105, 0.2);
  }
</style>
