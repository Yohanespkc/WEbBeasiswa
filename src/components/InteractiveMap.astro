  </div>

  <!-- Unified Stats Dashboard -->
  <div class="national-stats-dashboard glass-panel mt-8 p-6" id="national-dashboard">
    <div class="flex justify-between items-center mb-6 flex-wrap gap-4">
      <div>
        <h4 class="font-serif text-gold flex items-center gap-2 mb-1" id="dashboard-title" style="margin: 0;">
          📈 Rata-Rata Hasil Pretest & Posttest Nasional
        </h4>
        <p class="text-xs text-muted" id="dashboard-subtitle" style="margin: 0;">
          Peningkatan kompetensi numerasi di 127 Kabupaten/Kota yang telah sukses terintervensi metode GASING.
        </p>
      </div>
      
      <!-- Actions Container (Reset Button & Tabs) -->
      <div class="flex gap-2 items-center flex-wrap">
        <button class="dashboard-reset-btn hidden" id="btn-dash-reset" style="margin-right: 8px;">🔄 Kembali ke Nasional</button>
        <div class="flex gap-2">
          <button class="dashboard-tab-btn active" id="btn-dash-guru">👨‍🏫 Rata-rata Guru</button>
          <button class="dashboard-tab-btn" id="btn-dash-siswa">👨‍🎓 Rata-rata Siswa</button>
        </div>
      </div>
    </div>

    <!-- Chart Panel -->
    <div class="dashboard-chart-container" id="dashboard-chart-canvas">
      <!-- Dynamic SVG injected here -->
    </div>
  </div>

  <!-- Detail & Video Modal -->
  <div class="video-modal pointer-events-none opacity-0 fixed inset-0 z-[100] flex items-center justify-center p-6 bg-slate-950/85 backdrop-blur-md transition-all duration-300" id="video-modal">
    <div class="modal-card glass-panel p-6 max-w-4xl w-full relative">
      <button class="modal-close-btn" id="modal-close-btn">✖</button>
      <h3 class="modal-title font-serif text-xl text-center text-gold mb-4" id="modal-title">Pelatihan GASING di Kabupaten</h3>
      
      <!-- Video Player Column (Now centered and full width) -->
      <div class="modal-col-video">
        <div class="video-wrapper">
          <img
            id="modal-default-img"
            src="/assets/images/default_kabupaten.png"
            alt="Dokumentasi Pelatihan GASING"
            class="w-full h-full object-cover"
          />
          <iframe
            id="modal-iframe"
            src=""
            title="Video Pelatihan GASING"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="hidden"
          ></iframe>
        </div>
        <p class="text-xs text-muted text-center mt-3 video-description">Mendengar keceriaan anak-anak belajar numerasi lewat melodi lagu daerah.</p>
        
        <!-- Putar Video Lainnya Button -->
        <button class="btn-other-video" id="btn-other-video">🎥 Putar Video Lainnya (0 Video Terkait)</button>
      </div>
    </div>
