</div>

<script define:vars={{ regionsJson, kabupatenDataJson, siswaDataJson, kabVideosMapJson, nasionalAggregateJson, siswaNasionalAggregateJson, provinsiListJson, provinsiAggregatesJson, siswaProvinsiAggregatesJson }}>
  // Parse regions and stats data passed from Astro
  const regions = JSON.parse(regionsJson);
  const kabupatenData = JSON.parse(kabupatenDataJson);
  const siswaData = JSON.parse(siswaDataJson);
  const kabVideosMap = JSON.parse(kabVideosMapJson);
  const nasionalAggregate = JSON.parse(nasionalAggregateJson);
  const siswaNasionalAggregate = JSON.parse(siswaNasionalAggregateJson);
  const provinsiList = JSON.parse(provinsiListJson);
  const provinsiAggregates = JSON.parse(provinsiAggregatesJson);
  const siswaProvinsiAggregates = JSON.parse(siswaProvinsiAggregatesJson);

  class InteractiveMap {
    constructor(container) {
      this.container = container;
      this.canvasContainer = container.querySelector('.map-canvas-container');
      this.loadingEl = container.querySelector('.map-loading');
      this.modal = document.getElementById('video-modal');
      this.modalClose = document.getElementById('modal-close-btn');
      this.iframe = document.getElementById('modal-iframe');
      this.defaultImg = document.getElementById('modal-default-img');

      this.currentKabName = '';
      this.currentProvName = '';
      this.currentDashboardTab = 'guru'; // default dashboard tab
      this.currentDashboardState = 'nasional'; // default dashboard state
      
      this.currentRegion = null;
      this.currentVideoId = '';

      this.init();
    }

    async init() {
      await this.loadMap();
      this.renderPins();
      this.setupModalEvents();
      this.setupDashboardEvents();
      this.setupSearchEvents();
      this.renderDashboardStats();

      // Close search results dropdown when clicking anywhere on the map canvas
      if (this.canvasContainer) {
        this.canvasContainer.addEventListener('click', () => {
          const searchResults = document.getElementById('map-search-results');
          if (searchResults) {
            searchResults.classList.add('hidden');
          }
        });
      }
    }

    async loadMap() {
      try {
        const res = await fetch('/indonesia.svg');
        const svgText = await res.text();
        
        if (this.loadingEl) this.loadingEl.remove();

        const parser = new DOMParser();
        const doc = parser.parseFromString(svgText, 'image/svg+xml');
        const svgEl = doc.querySelector('svg');
        
        if (svgEl) {
          svgEl.setAttribute('class', 'w-full h-auto drop-shadow-2xl');
          svgEl.removeAttribute('style');
          
          const markersGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
          markersGroup.setAttribute('id', 'markers-container');
          svgEl.appendChild(markersGroup);

          this.canvasContainer.appendChild(svgEl);
          this.svg = svgEl;
          this.markersContainer = markersGroup;
        }
      } catch (e) {
        console.error("Gagal memuat peta Indonesia SVG:", e);
      }
    }

    findStats(kabName) {
      const clean = (s) => s.toLowerCase().replace(/^(kab|kabupaten|kota)\.?\s+/g, '').trim();
      const cleanName = clean(kabName);
      const gEntry = kabupatenData.find(d => clean(d.kabupaten) === cleanName);
      const sEntry = siswaData.find(d => clean(d.kabupaten) === cleanName);
      return { gEntry, sEntry };
    }

    getProvinceForKabupaten(kabName, fallbackProv) {
      const { gEntry, sEntry } = this.findStats(kabName);
      const entry = gEntry || sEntry;
      if (entry) return entry.provinsi;
      
      const kabLower = kabName.toLowerCase();
      if (kabLower.includes('aceh')) return 'Aceh';
      if (kabLower.includes('humbahas') || kabLower.includes('humbang')) return 'Sumatera Utara';
      if (kabLower.includes('dairi')) return 'Sumatera Utara';
      if (kabLower.includes('pakpak')) return 'Sumatera Utara';
      if (kabLower.includes('toba')) return 'Sumatera Utara';
      if (kabLower.includes('samosir')) return 'Sumatera Utara';
      if (kabLower.includes('manggarai')) return 'Nusa Tenggara Timur';
      if (kabLower.includes('belu')) return 'Nusa Tenggara Timur';
      if (kabLower.includes('ambon')) return 'Maluku';
      if (kabLower.includes('seram')) return 'Maluku';
      if (kabLower.includes('sarmi')) return 'Papua Induk';
      if (kabLower.includes('jayapura')) return 'Papua Induk';
      if (kabLower.includes('biak')) return 'Papua Induk';
      if (kabLower.includes('yapen')) return 'Papua Induk';
      if (kabLower.includes('waropen')) return 'Papua Induk';
      if (kabLower.includes('supiori')) return 'Papua Induk';
      if (kabLower.includes('keerom')) return 'Papua Induk';
      if (kabLower.includes('kobagma')) return 'Papua Pegunungan';
      if (kabLower.includes('ilugwa')) return 'Papua Pegunungan';
      if (kabLower.includes('tolikara')) return 'Papua Pegunungan';
      if (kabLower.includes('lanny')) return 'Papua Pegunungan';
      if (kabLower.includes('nduga')) return 'Papua Pegunungan';
      if (kabLower.includes('jayawijaya')) return 'Papua Pegunungan';
      if (kabLower.includes('mamberamo')) return 'Papua Pegunungan';
      if (kabLower.includes('maybrat')) return 'Papua Barat Daya';
      if (kabLower.includes('sorong')) return 'Papua Barat Daya';
      if (kabLower.includes('manokwari')) return 'Papua Barat';
      if (kabLower.includes('pegunungan arfak')) return 'Papua Barat';
      if (kabLower.includes('bintuni')) return 'Papua Barat';
      if (kabLower.includes('wondama')) return 'Papua Barat';
      if (kabLower.includes('puncak jaya')) return 'Papua Tengah';
      if (kabLower.includes('puncak')) return 'Papua Tengah';
      if (kabLower.includes('mimika')) return 'Papua Tengah';
      if (kabLower.includes('nabire')) return 'Papua Tengah';
      if (kabLower.includes('paniai')) return 'Papua Tengah';
      if (kabLower.includes('dogiyai')) return 'Papua Tengah';
      if (kabLower.includes('deiyai')) return 'Papua Tengah';
      if (kabLower.includes('intan jaya')) return 'Papua Tengah';
      if (kabLower.includes('mappi')) return 'Papua Selatan';
      if (kabLower.includes('bojonegoro')) return 'Jawa Timur';
      if (kabLower.includes('banyuwangi')) return 'Jawa Timur';
      if (kabLower.includes('sumedang')) return 'Jawa Barat';
      if (kabLower.includes('karanganyar')) return 'Jawa Tengah';
      if (kabLower.includes('magetan')) return 'Jawa Timur';
      if (kabLower.includes('bangli')) return 'Bali';
      if (kabLower.includes('bangka')) return 'Kepulauan Bangka Belitung';
      if (kabLower.includes('kupang')) return 'Nusa Tenggara Timur';
      
      return fallbackProv;
    }

    renderPins() {
      if (!this.markersContainer) return;
      regions.forEach((reg) => {
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.setAttribute('class', 'map-pin cursor-pointer');
        g.setAttribute('data-name', reg.name);
        g.setAttribute('data-id', reg.id);

        const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        dot.setAttribute('cx', reg.x.toString());
        dot.setAttribute('cy', reg.y.toString());
        dot.setAttribute('r', '3.5');
        dot.setAttribute('fill', '#fbbf24');
        dot.setAttribute('stroke', '#ffffff');
        dot.setAttribute('stroke-width', '1');

        g.appendChild(dot);

        // Simple text hover name label display
        g.addEventListener('mouseenter', () => this.showHoverLabel(reg.name, reg));
        g.addEventListener('mouseleave', () => this.hideHoverLabel());

        // Click events
        g.addEventListener('click', () => {
          this.playVideo(reg.id, reg.name);
          this.highlightMapPin(reg.name);
        });

        this.markersContainer.appendChild(g);
      });
    }

    showHoverLabel(name, reg) {
      if (this.markersContainer && reg) {
        let hoverLabel = document.getElementById('hover-map-label');
        if (!hoverLabel) {
          hoverLabel = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          hoverLabel.setAttribute('id', 'hover-map-label');
          hoverLabel.setAttribute('fill', '#ffffff');
          hoverLabel.setAttribute('font-size', '8');
          hoverLabel.setAttribute('font-weight', '700');
          hoverLabel.setAttribute('text-anchor', 'middle');
          hoverLabel.setAttribute('font-family', 'Inter, sans-serif');
          hoverLabel.setAttribute('stroke', '#000000');
          hoverLabel.setAttribute('stroke-width', '1.2');
          hoverLabel.setAttribute('paint-order', 'stroke fill');
          hoverLabel.style.pointerEvents = 'none';
          this.markersContainer.appendChild(hoverLabel);
        }
        hoverLabel.setAttribute('x', reg.x.toString());
        hoverLabel.setAttribute('y', (reg.y - 8).toString());
        hoverLabel.textContent = name;
        hoverLabel.style.display = 'block';
      }
    }

    hideHoverLabel() {
      const hoverLabel = document.getElementById('hover-map-label');
      if (hoverLabel) {
        hoverLabel.style.display = 'none';
      }
    }

    highlightMapPin(name) {
      const reg = regions.find(r => r.name === name);
      if (this.markersContainer && reg) {
        const oldLabel = document.getElementById('active-map-label');
        if (oldLabel) oldLabel.remove();
        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('id', 'active-map-label');
        label.setAttribute('x', reg.x.toString());
        label.setAttribute('y', (reg.y - 8).toString());
        label.setAttribute('fill', '#fbbf24');
        label.setAttribute('font-size', '8');
        label.setAttribute('font-weight', '900');
        label.setAttribute('text-anchor', 'middle');
        label.setAttribute('font-family', 'Inter, sans-serif');
        label.setAttribute('stroke', '#000000');
        label.setAttribute('stroke-width', '1.5');
        label.setAttribute('paint-order', 'stroke fill');
        label.textContent = name;
        this.markersContainer.appendChild(label);
      }
    }

    playVideo(videoId, name) {
      if (!this.modal || !this.iframe) return;
      const reg = regions.find(r => r.name === name);
      this.currentRegion = reg;
      this.currentVideoId = videoId;
      this.currentKabName = name;
      this.currentDashboardState = 'kabupaten';

      this.modal.querySelector('.modal-title').textContent = `Pelatihan GASING di Kab. ${name}`;
      this.iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
      
      if (this.defaultImg) this.defaultImg.classList.add('hidden');
      this.iframe.classList.remove('hidden');
      
      const descEl = this.container.querySelector('.video-description');
      if (descEl) {
        const clean = (s) => s.toLowerCase().replace(/^(kab|kabupaten|kota)\.?\s+/g, '').trim();
        const normName = clean(name);
        const allVideos = kabVideosMap[normName] || [];
        const videoObj = allVideos.find(v => v.id === videoId);
        descEl.textContent = videoObj ? `Menampilkan: ${videoObj.label}` : `Mendengar keceriaan anak-anak belajar numerasi lewat melodi lagu daerah.`;
      }

      this.renderDashboardStats();
      
      const clean = (s) => s.toLowerCase().replace(/^(kab|kabupaten|kota)\.?\s+/g, '').trim();
      const normName = clean(name);
      const allKabVideos = kabVideosMap[normName] || [];
      const otherVideos = allKabVideos.filter(v => v.id !== videoId);

      const btnOther = document.getElementById('btn-other-video');
      if (btnOther) {
        if (otherVideos.length > 0) {
          btnOther.style.display = 'block';
          btnOther.textContent = `🎥 Putar Video Lainnya (${otherVideos.length} Video Terkait)`;
          btnOther.removeAttribute('disabled');
          btnOther.style.opacity = '1';
          btnOther.style.cursor = 'pointer';
        } else {
          btnOther.textContent = `🎥 Hanya ada 1 video untuk wilayah ini`;
          btnOther.setAttribute('disabled', 'true');
          btnOther.style.opacity = '0.5';
          btnOther.style.cursor = 'not-allowed';
        }
      }

      this.modal.classList.remove('pointer-events-none', 'opacity-0');
      this.modal.classList.add('opacity-100');
    }

    playRandomVideo() {
      if (!this.iframe || !this.currentKabName) return;
      const clean = (s) => s.toLowerCase().replace(/^(kab|kabupaten|kota)\.?\s+/g, '').trim();
      const normName = clean(this.currentKabName);
      const allKabVideos = kabVideosMap[normName] || [];
      const otherVideos = allKabVideos.filter(v => v.id !== this.currentVideoId);
      if (otherVideos.length === 0) return;

      const randomVideo = otherVideos[Math.floor(Math.random() * otherVideos.length)];
      this.currentVideoId = randomVideo.id;
      this.iframe.src = `https://www.youtube.com/embed/${randomVideo.id}?autoplay=1`;
      
      if (this.defaultImg) this.defaultImg.classList.add('hidden');
      this.iframe.classList.remove('hidden');
      
      const descEl = this.container.querySelector('.video-description');
      if (descEl) { descEl.textContent = `Menampilkan: ${randomVideo.label}`; }
    }

    setupModalEvents() {
      if (this.modalClose) { this.modalClose.addEventListener('click', () => this.closeModal()); }
      if (this.modal) { this.modal.addEventListener('click', (e) => { if (e.target === this.modal) this.closeModal(); }); }
      const btnOther = document.getElementById('btn-other-video');
      if (btnOther) { btnOther.addEventListener('click', () => this.playRandomVideo()); }
    }

    setupDashboardEvents() {
      const tabGuruDash = document.getElementById('btn-dash-guru');
      const tabSiswaDash = document.getElementById('btn-dash-siswa');
      if (tabGuruDash) { tabGuruDash.addEventListener('click', () => { this.currentDashboardTab = 'guru'; this.renderDashboardStats(); }); }
      if (tabSiswaDash) { tabSiswaDash.addEventListener('click', () => { this.currentDashboardTab = 'siswa'; this.renderDashboardStats(); }); }

      const btnReset = document.getElementById('btn-dash-reset');
      if (btnReset) {
        btnReset.addEventListener('click', () => {
          this.currentDashboardState = 'nasional';
          this.currentKabName = '';
          this.currentProvName = '';
          this.renderDashboardStats();
          const oldLabel = document.getElementById('active-map-label');
          if (oldLabel) oldLabel.remove();
          
          // Clear search input on reset
          const searchInput = document.getElementById('map-search-input');
          if (searchInput) searchInput.value = '';
        });
      }
    }

    setupSearchEvents() {
      const searchInput = document.getElementById('map-search-input');
      const searchResults = document.getElementById('map-search-results');
      const clearBtn = document.getElementById('map-search-clear-btn');
      
      if (searchInput && searchResults) {
        const updateClearBtn = () => {
          if (clearBtn) {
            if (searchInput.value) {
              clearBtn.classList.remove('hidden');
            } else {
              clearBtn.classList.add('hidden');
            }
          }
        };

        searchInput.addEventListener('input', () => {
          this.renderSearchResults();
          updateClearBtn();
        });

        searchInput.addEventListener('focus', () => {
          this.renderSearchResults();
          updateClearBtn();
        });

        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            const firstItem = searchResults.querySelector('.search-result-item');
            if (firstItem) {
              firstItem.click();
            }
          }
        });

        if (clearBtn) {
          clearBtn.addEventListener('click', () => {
            searchInput.value = '';
            searchResults.innerHTML = '';
            searchResults.classList.add('hidden');
            clearBtn.classList.add('hidden');
            searchInput.focus();
          });
        }

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (target && !searchInput.contains(target) && !searchResults.contains(target) && (!clearBtn || !clearBtn.contains(target))) {
            searchResults.classList.add('hidden');
          }
        });
      }
    }

    renderSearchResults() {
      const searchInput = document.getElementById('map-search-input');
      const searchResults = document.getElementById('map-search-results');
      if (!searchInput || !searchResults) return;

      const query = searchInput.value.toLowerCase().trim();
      if (!query) {
        searchResults.innerHTML = '';
        searchResults.classList.add('hidden');
        return;
      }

      const qClean = query.replace(/^provinsi\s+/g, '').trim();

      // 1. Filter provinces matching query
      const matchedProvinces = provinsiList.filter(prov => {
        const provLower = prov.toLowerCase();
        const hasPapuaBarat = qClean.includes('papua barat');
        const hasDaya = qClean.includes('daya');
        if (hasPapuaBarat && !hasDaya && provLower.includes('papua barat daya')) {
          return false;
        }
        return provLower.includes(query);
      });

      // 2. Filter kabupaten regions matching query
      const sortedRegions = [...regions].sort((a, b) => a.name.localeCompare(b.name));
      const matchedKabupatens = sortedRegions.filter(reg => {
        const { gEntry, sEntry } = this.findStats(reg.name);
        const entry = gEntry || sEntry;
        const province = this.getProvinceForKabupaten(reg.name, 'Indonesia');
        const provLower = province.toLowerCase();
        
        const hasPapuaBarat = qClean.includes('papua barat');
        const hasDaya = qClean.includes('daya');
        if (hasPapuaBarat && !hasDaya && provLower.includes('papua barat daya')) {
          return false;
        }
        return reg.name.toLowerCase().includes(query) || provLower.includes(query);
      });

      // Combine matches: provinces first, then kabupatens (without limits to allow scrolling)
      const combinedMatches = [];
      matchedProvinces.forEach(prov => {
        combinedMatches.push({ type: 'provinsi', name: prov });
      });
      matchedKabupatens.forEach(reg => {
        combinedMatches.push({ type: 'kabupaten', reg });
      });

      if (combinedMatches.length === 0) {
        searchResults.innerHTML = '<div class="search-no-results">Wilayah tidak ditemukan</div>';
        searchResults.classList.remove('hidden');
        return;
      }

      let html = '';
      combinedMatches.forEach(match => {
        if (match.type === 'provinsi') {
          const prov = match.name;
          const gProv = provinsiAggregates[prov];
          const sProv = siswaProvinsiAggregates[prov];
          let pctInfo = '';
          if (gProv) {
            const pre = gProv.bakalkubagi.pre;
            const post = gProv.bakalkubagi.post;
            const pct = pre > 0 ? ((post - pre) / pre * 100) : 0;
            pctInfo = `(+${pct.toFixed(0)}% Guru)`;
          } else if (sProv) {
            const pre = sProv.bakalkubagi.pre;
            const post = sProv.bakalkubagi.post;
            const pct = pre > 0 ? ((post - pre) / pre * 100) : 0;
            pctInfo = `(+${pct.toFixed(0)}% Siswa)`;
          }

          const isActive = (this.currentDashboardState === 'provinsi' && prov === this.currentProvName);
          const activeClass = isActive ? 'active-search-item' : '';

          html += `
            <div class="search-result-item ${activeClass}" data-type="provinsi" data-name="${prov}">
              <span class="search-result-name">🌐 Provinsi ${prov}</span>
              <span class="search-result-detail">Indonesia ${pctInfo}</span>
            </div>
          `;
        } else {
          const reg = match.reg;
          const { gEntry, sEntry } = this.findStats(reg.name);
          const entry = gEntry || sEntry;
          const province = this.getProvinceForKabupaten(reg.name, 'Indonesia');
          
          let pctInfo = '';
          if (gEntry) {
            const pre = gEntry.bakalkubagiPre;
            const post = gEntry.bakalkubagiPost;
            const pct = pre > 0 ? ((post - pre) / pre * 100) : 0;
            pctInfo = `(+${pct.toFixed(0)}% Guru)`;
          } else if (sEntry) {
            const pre = sEntry.bakalkubagiPre;
            const post = sEntry.bakalkubagiPost;
            const pct = pre > 0 ? ((post - pre) / pre * 100) : 0;
            pctInfo = `(+${pct.toFixed(0)}% Siswa)`;
          } else {
            pctInfo = '(+340% Peningkatan)';
          }

          const isActive = (this.currentDashboardState === 'kabupaten' && reg.name === this.currentKabName);
          const activeClass = isActive ? 'active-search-item' : '';

          html += `
            <div class="search-result-item ${activeClass}" data-type="kabupaten" data-id="${reg.id}" data-name="${reg.name}">
              <span class="search-result-name">📍 ${reg.name}</span>
              <span class="search-result-detail">${province} ${pctInfo}</span>
            </div>
          `;
        }
      });

      searchResults.innerHTML = html;
      searchResults.classList.remove('hidden');

      searchResults.querySelectorAll('.search-result-item').forEach(item => {
        item.addEventListener('click', () => {
          const type = item.getAttribute('data-type');
          const name = item.getAttribute('data-name');
          
          searchInput.value = name;
          searchResults.classList.add('hidden');

          if (type === 'provinsi') {
            this.currentDashboardState = 'provinsi';
            this.currentProvName = name;
            this.currentKabName = '';
            
            const oldLabel = document.getElementById('active-map-label');
            if (oldLabel) oldLabel.remove();
            
            // Find all kabupatens in this province
            const provKabupatens = kabupatenData.filter(k => k.provinsi === name).map(k => k.kabupaten);
            // Collect all video IDs for these kabupatens
            const provVideos = [];
            provKabupatens.forEach(kab => {
              const clean = (s) => s.toLowerCase().replace(/^(kab|kabupaten|kota)\.?\s+/g, '').trim();
              const normName = clean(kab);
              const vids = kabVideosMap[normName] || [];
              vids.forEach(v => {
                provVideos.push({ kabName: kab, videoId: v.id, label: v.label });
              });
            });

            // If there is at least one video, play it
            if (provVideos.length > 0) {
              const selectedVideo = provVideos[0];
              this.playVideo(selectedVideo.videoId, selectedVideo.kabName);
            }

            // Restore dashboard state to provinsi and render!
            this.currentDashboardState = 'provinsi';
            this.currentProvName = name;
            this.currentKabName = '';
            this.renderDashboardStats();
          } else {
            const id = item.getAttribute('data-id');
            this.currentDashboardState = 'kabupaten';
            this.currentKabName = name;
            this.currentProvName = '';
            this.playVideo(id, name);
            this.highlightMapPin(name);
          }
        });
      });
    }

    renderDashboardStats() {
      const chartCanvas = document.getElementById('dashboard-chart-canvas');
      if (!chartCanvas) return;
      
      const resetBtn = document.getElementById('btn-dash-reset');
      const titleEl = document.getElementById('dashboard-title');
      const subtitleEl = document.getElementById('dashboard-subtitle');

      // Update reset button visibility and titles
      if (this.currentDashboardState === 'kabupaten') {
        if (resetBtn) resetBtn.classList.remove('hidden');
        if (titleEl) titleEl.textContent = `📊 Hasil Pelatihan GASING - Kab. ${this.currentKabName}`;
        if (subtitleEl) {
          const { gEntry, sEntry } = this.findStats(this.currentKabName);
          const entry = this.currentDashboardTab === 'guru' ? gEntry : sEntry;
          const countStr = entry ? ` (${entry.peserta.toLocaleString('id-ID')} Peserta Pelatihan)` : '';
          subtitleEl.textContent = `Peningkatan kompetensi numerasi guru dan siswa di Kabupaten ${this.currentKabName}${countStr}.`;
        }
      } else if (this.currentDashboardState === 'provinsi') {
        if (resetBtn) resetBtn.classList.remove('hidden');
        if (titleEl) titleEl.textContent = `📊 Hasil Pelatihan GASING - Provinsi ${this.currentProvName}`;
        if (subtitleEl) {
          const gProv = provinsiAggregates[this.currentProvName];
          const sProv = siswaProvinsiAggregates[this.currentProvName];
          const entry = this.currentDashboardTab === 'guru' ? gProv : sProv;
          const countStr = entry ? ` (${entry.totalPeserta.toLocaleString('id-ID')} Peserta Pelatihan di ${entry.kabupatenCount} Kabupaten/Kota)` : '';
          subtitleEl.textContent = `Rata-rata peningkatan kompetensi numerasi guru dan siswa di Provinsi ${this.currentProvName}${countStr}.`;
        }
      } else {
        if (resetBtn) resetBtn.classList.add('hidden');
        if (titleEl) titleEl.textContent = `📈 Rata-Rata Hasil Pretest & Posttest Nasional`;
        if (subtitleEl) subtitleEl.textContent = `Peningkatan kompetensi numerasi di 127 Kabupaten/Kota yang telah sukses terintervensi metode GASING.`;
      }
      
      // Update tab buttons style
      const tabGuru = document.getElementById('btn-dash-guru');
      const tabSiswa = document.getElementById('btn-dash-siswa');
      if (tabGuru && tabSiswa) {
        tabGuru.classList.toggle('active', this.currentDashboardTab === 'guru');
        tabSiswa.classList.toggle('active', this.currentDashboardTab === 'siswa');
      }

      let metrics = [];
      let entry = null;

      if (this.currentDashboardState === 'kabupaten') {
        const { gEntry, sEntry } = this.findStats(this.currentKabName);
        entry = this.currentDashboardTab === 'guru' ? gEntry : sEntry;
        
        if (!entry) {
          chartCanvas.innerHTML = '<div style="text-align: center; color: rgba(255, 255, 255, 0.2); font-size: 0.85rem; padding: 60px 0; font-family: Inter, sans-serif;">Data statistik tidak tersedia untuk wilayah ini</div>';
          return;
        }

        metrics = [
          { label: 'Penjumlahan', code: '➕ Tambah', pre: entry.penjumlahanPre, post: entry.penjumlahanPost },
          { label: 'Perkalian', code: '✖️ Kali', pre: entry.perkalianPre, post: entry.perkalianPost },
          { label: 'Pengurangan', code: '➖ Kurang', pre: entry.penguranganPre, post: entry.penguranganPost },
          { label: 'Pembagian', code: '➗ Bagi', pre: entry.pembagianPre, post: entry.pembagianPost },
          { label: 'BakalKubagi', code: '🎯 BAKALKUBAGI', pre: entry.bakalkubagiPre, post: entry.bakalkubagiPost }
        ];
      } else if (this.currentDashboardState === 'provinsi') {
        const gProv = provinsiAggregates[this.currentProvName];
        const sProv = siswaProvinsiAggregates[this.currentProvName];
        entry = this.currentDashboardTab === 'guru' ? gProv : sProv;

        if (!entry) {
          chartCanvas.innerHTML = '<div style="text-align: center; color: rgba(255, 255, 255, 0.2); font-size: 0.85rem; padding: 60px 0; font-family: Inter, sans-serif;">Data statistik tidak tersedia untuk provinsi ini</div>';
          return;
        }

        metrics = [
          { label: 'Penjumlahan', code: '➕ Tambah', pre: entry.penjumlahan.pre, post: entry.penjumlahan.post },
          { label: 'Perkalian', code: '✖️ Kali', pre: entry.perkalian.pre, post: entry.perkalian.post },
          { label: 'Pengurangan', code: '➖ Kurang', pre: entry.pengurangan.pre, post: entry.pengurangan.post },
          { label: 'Pembagian', code: '➗ Bagi', pre: entry.pembagian.pre, post: entry.pembagian.post },
          { label: 'BakalKubagi', code: '🎯 BAKALKUBAGI', pre: entry.bakalkubagi.pre, post: entry.bakalkubagi.post }
        ];
      } else {
        // Nasional
        entry = this.currentDashboardTab === 'guru' ? nasionalAggregate : siswaNasionalAggregate;
        metrics = [
          { label: 'Penjumlahan', code: '➕ Tambah', pre: entry.penjumlahan.pre, post: entry.penjumlahan.post },
          { label: 'Perkalian', code: '✖️ Kali', pre: entry.perkalian.pre, post: entry.perkalian.post },
          { label: 'Pengurangan', code: '➖ Kurang', pre: entry.pengurangan.pre, post: entry.pengurangan.post },
          { label: 'Pembagian', code: '➗ Bagi', pre: entry.pembagian.pre, post: entry.pembagian.post },
          { label: 'BakalKubagi', code: '🎯 BAKALKUBAGI', pre: entry.bakalkubagi.pre, post: entry.bakalkubagi.post }
        ];
      }

      // Draw SVG Grafana Graph
      const valToY = (val) => 180 - (val * 1.4); // Maps 0-100 to Y coordinates 180 to 40
      
      let svgHtml = `
        <svg viewBox="0 0 500 220" class="w-full h-auto" style="overflow: visible;">
          <!-- SVG Legend -->
          <g transform="translate(60, 12)">
            <rect x="0" y="0" width="8" height="8" fill="#ff780a" rx="1.5" />
            <text x="12" y="8" fill="#9fa7ad" font-size="8.5" font-family="Inter, sans-serif">Pre-test</text>
            <rect x="140" y="0" width="8" height="8" fill="#73bf69" rx="1.5" />
            <text x="152" y="8" fill="#9fa7ad" font-size="8.5" font-family="Inter, sans-serif">Post-test</text>
          </g>
          <line x1="45" y1="180" x2="480" y2="180" stroke="#4f5d65" stroke-width="1.5" />
      `;

      metrics.forEach((m, idx) => {
        const x = 85 + idx * 86;
        const preY = valToY(m.pre);
        const postY = valToY(m.post);
        svgHtml += `
          <rect x="${x - 18}" y="${preY}" width="16" height="${180 - preY}" fill="#ff780a" rx="2" />
          <rect x="${x + 2}" y="${postY}" width="16" height="${180 - postY}" fill="#73bf69" rx="2" />
          
          <!-- Score numbers above the bars -->
          <text x="${x - 10}" y="${preY - 5}" fill="#ff780a" font-size="7.5" font-weight="bold" text-anchor="middle" font-family="Inter, sans-serif">${m.pre.toFixed(0)}</text>
          <text x="${x + 10}" y="${postY - 5}" fill="#73bf69" font-size="7.5" font-weight="bold" text-anchor="middle" font-family="Inter, sans-serif">${m.post.toFixed(0)}</text>

          <text x="${x}" y="200" fill="#c7d2d6" font-size="8.5" font-weight="700" text-anchor="middle" font-family="Inter, sans-serif">${m.code}</text>
        `;
      });
      svgHtml += `</svg>`;
      chartCanvas.innerHTML = svgHtml;
    }

    closeModal() {
      if (!this.modal || !this.iframe) return;
      this.modal.classList.add('pointer-events-none', 'opacity-0');
      this.modal.classList.remove('opacity-100');
      this.iframe.src = '';
      
      this.iframe.classList.add('hidden');
      if (this.defaultImg) this.defaultImg.classList.remove('hidden');
      
      this.modal.querySelector('.modal-title').textContent = 'Pelatihan GASING di Kabupaten';
      
      const descEl = this.container.querySelector('.video-description');
      if (descEl) {
        descEl.textContent = 'Mendengar keceriaan anak-anak belajar numerasi lewat melodi lagu daerah.';
      }

      const btnOther = document.getElementById('btn-other-video');
      if (btnOther) {
        btnOther.style.display = 'none';
      }

      const oldLabel = document.getElementById('active-map-label');
      if (oldLabel) oldLabel.remove();
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', () => {
    const mapCard = document.querySelector('.map-card');
    if (mapCard) {
      new InteractiveMap(mapCard);
    }
  });
</script>

