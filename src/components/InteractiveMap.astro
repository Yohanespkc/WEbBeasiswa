import { BUDAYA_REGISTRY } from '../data/budayaRegistry';
import { KABUPATEN_DATA, SISWA_DATA, NASIONAL_AGGREGATE, SISWA_NASIONAL_AGGREGATE } from '../data/statistikRegistry';
import { LAGU_REGISTRY } from '../data/laguRegistry';
import { MENCONGAK_REGISTRY } from '../data/mencongakRegistry';

// Helper function to normalize names for mapping
function normalizeName(name: string): string {
  return name.toLowerCase().replace(/^(kab|kabupaten|kota)\.?\s+/g, '').trim();
}

// Define programmatic ignore list for non-kabupaten entries
const ignoredNames = ['kemenag', 'tni', 'akmil', 'upi', 'uncen', 'universitas'];

// Filter the main regions list for map pins rendering
const filteredBudaya = BUDAYA_REGISTRY.filter(r => {
  const norm = r.name.toLowerCase().trim();
  return !ignoredNames.some(ignored => norm.includes(ignored));
});

const regionsJson = JSON.stringify(filteredBudaya);
const kabupatenDataJson = JSON.stringify(KABUPATEN_DATA);
const siswaDataJson = JSON.stringify(SISWA_DATA);
const nasionalAggregateJson = JSON.stringify(NASIONAL_AGGREGATE);
const siswaNasionalAggregateJson = JSON.stringify(SISWA_NASIONAL_AGGREGATE);

// Build a unified video map grouped by normalized kabupaten name, ignoring non-kabupatens
const kabupatenVideosMap: Record<string, { id: string, label: string }[]> = {};

function addVideo(kabName: string, id: string, label: string) {
  const norm = normalizeName(kabName);
  if (!kabupatenVideosMap[norm]) {
    kabupatenVideosMap[norm] = [];
  }
  // Avoid duplicate video IDs
  if (!kabupatenVideosMap[norm].some(v => v.id === id)) {
    kabupatenVideosMap[norm].push({ id, label });
  }
}

// 1. Process BUDAYA_REGISTRY
BUDAYA_REGISTRY.forEach(reg => {
  const normName = reg.name.toLowerCase().trim();
  if (ignoredNames.some(ignored => normName.includes(ignored))) return;

  addVideo(reg.name, reg.id, 'Video Pelatihan Daerah');
  if (reg.videos) {
    reg.videos.forEach(v => {
      addVideo(reg.name, v.id, v.label || 'Video Lagu Pasangan 10');
    });
  }
});

// 2. Process LAGU_REGISTRY
Object.keys(LAGU_REGISTRY).forEach(category => {
  LAGU_REGISTRY[category].forEach(reg => {
    const normName = reg.name.toLowerCase().trim();
    if (ignoredNames.some(ignored => normName.includes(ignored))) return;

    addVideo(reg.name, reg.id, `Lagu GASING: ${category}`);
    if (reg.videos) {
      reg.videos.forEach(v => {
        addVideo(reg.name, v.id, v.label || `Lagu GASING: ${category}`);
      });
    }
  });
});

// 3. Process MENCONGAK_REGISTRY
Object.keys(MENCONGAK_REGISTRY).forEach(category => {
  MENCONGAK_REGISTRY[category].forEach(reg => {
    const normName = reg.name.toLowerCase().trim();
    if (ignoredNames.some(ignored => normName.includes(ignored))) return;

    if (reg.id) {
      addVideo(reg.name, reg.id, `Video Pelatihan: ${category}`);
    }
    if (reg.videos) {
      reg.videos.forEach(vidId => {
        addVideo(reg.name, vidId, `Video Pelatihan: ${category}`);
      });
    }
  });
});

const kabVideosMapJson = JSON.stringify(kabupatenVideosMap);
