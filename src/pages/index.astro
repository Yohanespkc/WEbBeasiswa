---
import Layout from '../layouts/Layout.astro';
import InteractiveMap from '../components/InteractiveMap.astro';
import { emotionalStories, boardMembers, metrics } from '../data/stories';

const realStories = emotionalStories.filter(s => !s.isTestimoniBook);
const bookStories = emotionalStories.filter(s => s.isTestimoniBook);
---

<Layout title="Beranda" description="Membuka kesempatan bagi para trainer hebat GASING untuk melangkah lebih jauh melalui program Beasiswa S2 & S3, demi masa depan numerasi Indonesia yang cemerlang.">
  <!-- Hero Section -->
  <section class="hero-section text-center relative overflow-hidden">
    <div class="hero-glow absolute inset-0 z-0"></div>
    <div class="container relative z-10 hero-content">
      <span class="hero-badge">🎓 PROGRAM BEASISWA NUSANTARA</span>
      <h1 class="hero-title">Membuka Pintu Pendidikan Lanjut<br/><span class="text-gold">S2 & S3 Trainer GASING</span></h1>
      <p class="hero-subtitle">Mereka adalah putra-putri terbaik bangsa yang telah melatih puluhan ribu guru dan anak di pelosok negeri. Mari berpartisipasi memberikan kesempatan bagi para trainer hebat ini untuk bertumbuh dan menempuh studi S2 serta S3 (dalam dan luar negeri), agar sekembalinya nanti, mereka dapat berkarya lebih jauh lagi dan memimpin perubahan pendidikan di Indonesia.</p>
      
      <div class="hero-actions">
        <a href="/donasi" class="btn btn-primary">Ikut Berpartisipasi</a>
        <a href="/trainers" class="btn btn-secondary">Mengenal Para Trainer</a>
      </div>
    </div>
  </section>

  <!-- Statistics Panel -->
  <section class="container relative z-10">
    <div class="grid-cols-4 statistics-grid">
      {metrics.map(metric => (
        <div class="glass-panel stat-card text-center">
          <h2 class="stat-value text-gold">{metric.value}</h2>
          <h4 class="stat-label">{metric.label}</h4>
          <p class="stat-desc text-xs mt-1">{metric.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Crisis & Mission Section -->
  <section class="section-padding crisis-mission-section relative z-10">
    <div class="container">
      <div class="glass-panel p-8 md:p-12 border border-white/10 bg-gradient-to-br from-primary-light/40 to-color-bg-dark rounded-3xl">
        <div class="grid-half items-center mb-8">
          <div>
            <span class="text-gold text-xs uppercase tracking-wider font-semibold block mb-2">📊 KONDISI NYATA PENDIDIKAN KITA</span>
            <h2 class="text-white text-3xl font-serif mb-6 leading-tight">Menjawab Krisis Numerasi & Mengobati "Math Anxiety"</h2>
            <p class="text-sm text-secondary leading-relaxed mb-4">
              Hasil penilaian PISA secara konsisten memperlihatkan tantangan besar numerasi nasional kita. Namun di balik angka statistik tersebut, terdapat jutaan anak yang memendam rasa takut, cemas, dan rendah diri setiap kali berhadapan dengan matematika—sebuah kondisi psikologis nyata yang dikenal sebagai <strong>"math anxiety"</strong> (kecemasan matematika).
            </p>
            <p class="text-sm text-secondary leading-relaxed">
              Kita ingin menyembuhkan kecemasan ini, mengubah trauma belajar menjadi kecintaan bereksplorasi, dan membuka pintu masa depan bagi anak-anak di kampung-kampung pelosok Nusantara. Metode pembelajaran yang menyenangkan dari dasar digunakan sepenuhnya sebagai instrumen pengabdian masyarakat demi kemajuan anak bangsa.
            </p>
          </div>

          <div class="glass-panel p-6 border border-amber-500/10 bg-amber-500/5 rounded-2xl">
            <h3 class="font-serif text-gold text-lg mb-4">Metodologi Konseptual: Menghilangkan Ketakutan</h3>
            <ul class="flex flex-col gap-4 text-xs list-none">
              <li class="flex items-start gap-3">
                <span class="text-gold font-bold">1. BAKALKUBAGI:</span>
                <div>
                  <p class="text-secondary font-medium">Menghilangkan Ketakutan Awal</p>
                  <p class="text-muted mt-0.5">Mengubah cara anak memandang Penjumlahan, Pengurangan, Perkalian, dan Pembagian mencongak cepat lewat konsep konkret dan asyik agar matematika tidak lagi menakutkan sejak dini.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold font-bold">2. PEDE:</span>
                <div>
                  <p class="text-secondary font-medium">Membangun Kepercayaan Diri (Pola, Estimasi, Desimal)</p>
                  <p class="text-muted mt-0.5">Mempertajam penalaran kognitif tingkat lanjut untuk melatih logika kritis anak agar merasa mandiri dan berdaya memecahkan masalah matematika sekolah dasar.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-gold font-bold">3. Sains & Fisika Lanjut:</span>
                <div>
                  <p class="text-secondary font-medium">Meruntuhkan Tembok Rumus</p>
                  <p class="text-muted mt-0.5">Menyederhanakan konsep matematika SMP, SMA, hingga rumus fisika tersulit agar dirasakan gampang, intuitif, dan melahirkan kecintaan pada sains.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <div class="pt-8 border-t border-white/10 grid-half">
          <div>
            <h3 class="font-serif text-white text-lg mb-3">🎓 Membedah Formula Pedagogis demi Kepentingan Publik</h3>
            <p class="text-xs text-secondary leading-relaxed">
              Para penerima beasiswa S2 dan S3 ini melakukan penelitian ilmiah mendalam bukan untuk mempromosikan metode secara eksklusif, melainkan untuk membedah mekanisme kognitif di balik akselerasi belajar anak. Hasil riset ini dirumuskan menjadi metodologi terbuka yang dapat diadaptasikan bebas oleh guru, orang tua, dan institusi pendidikan mana pun demi kepentingan orang banyak.
            </p>
          </div>
          <div>
            <h3 class="font-serif text-white text-lg mb-3">🌍 Menyembuhkan Trauma Belajar Matematika & Sains secara Global</h3>
            <p class="text-xs text-secondary leading-relaxed">
              Dukungan beasiswa ini berfokus membantu para guru menghasilkan karya ilmiah, modul ajar, dan terapi pedagogis untuk <strong>menyelamatkan anak-anak dari trauma serta rasa takut belajar matematika/sains</strong>. Karya nyata dari para pendidik kampung pelosok ini diproyeksikan menjadi solusi yang bermanfaat bagi pendidik di Indonesia maupun di seluruh dunia.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pooled Fund Policy Notice -->
  <section class="container relative z-10 mt-10">
    <div class="glass-panel p-8 border border-amber-500/20 bg-gradient-to-br from-amber-500/5 to-amber-500/10 rounded">
      <h4 class="font-bold text-amber-400 mb-3 font-serif text-base flex items-center justify-center gap-2">
        🎓 Misi Besar: 1.000 Guru Doktor (Ph.D.) Membangun Daerah
      </h4>
      <p class="text-sm text-muted leading-relaxed max-w-4xl mx-auto text-center">
        Saat ini, beasiswa gotong royong <strong>Dana Bersama</strong> sedang berjalan mendukung pendidikan untuk tahap pertama, yaitu <strong>80 Asisten Trainer (AT)</strong> di UPI, sedangkan <strong>2 Asisten Trainer (AT)</strong> di Columbia University didanai secara khusus. Namun, perjuangan kita tidak berhenti di sini.
      </p>
      <p class="text-sm text-muted leading-relaxed max-w-4xl mx-auto mt-3 text-center">
        Target besar kita adalah mengantarkan <strong>1.000 orang guru</strong> berprestasi mendapatkan gelar S2, dan setelah itu, kita akan membantu mereka melanjutkan studi hingga meraih gelar <strong>S3 (Ph.D.)</strong>. Goals utama dari program ini adalah melahirkan <strong>1.000 Doktor Pendidikan</strong> yang siap pulang kembali untuk membangun daerahnya masing-masing.
      </p>
      <div class="mt-4 p-4 rounded bg-amber-500/5 border border-amber-500/10 max-w-3xl mx-auto text-center">
        <p class="text-sm text-amber-100 font-serif italic">
          "Guru-guru ini berasal dari kampung-kampung pelosok Nusantara, mereka adalah mutiara terpendam yang memiliki hati tulus untuk membangun tanah kelahirannya."
        </p>
      </div>

      <!-- Visual Timeline for Batches (Road to 1.000 Doktor) -->
      <div class="mt-8 pt-8 border-t border-amber-500/20">
        <h5 class="text-center text-white font-serif font-semibold text-sm mb-8">📅 Peta Jalan Akumulasi & Proyeksi Target (2026 - 2036)</h5>
        
        <div class="roadmap-vertical-timeline">
          
          <div class="timeline-item current">
            <div class="timeline-badge">2026</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-gold font-bold">Fase Inisiasi (S2)</h4>
              <p class="text-xs text-white font-semibold mt-1">82 S2 Sedang Berjalan + Maks. 100 S2 Baru</p>
              <p class="text-[10px] text-muted mt-1">Pendidikan dasar di UPI (80 orang) & Columbia University (2 orang) ditambah seleksi beasiswa S2 baru.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2027</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Transisi S3 Pertama</h4>
              <p class="text-xs text-gold font-semibold mt-1">82 Program S3 + Maks. 200 S2 Baru</p>
              <p class="text-[10px] text-muted mt-1">Asisten Trainer batch pertama bersiap melanjutkan riset jenjang doktoral (S3).</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2028</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Peningkatan Kapasitas S3</h4>
              <p class="text-xs text-gold font-semibold mt-1">182 Program S3 + Maks. 200 S2 Baru</p>
              <p class="text-[10px] text-muted mt-1">Ekspansi riset terintegrasi dari guru-guru daerah 3T potensial.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2029</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Garis Depan Doktoral</h4>
              <p class="text-xs text-gold font-semibold mt-1">382 Program S3 + Maks. 200 S2 Baru</p>
              <p class="text-[10px] text-muted mt-1">Akumulasi penerimaan mahasiswa doktoral secara berkelanjutan.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2030</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Doktor Pertama Lulus</h4>
              <p class="text-xs text-success font-semibold mt-1">🎓 82 Sudah Ph.D. + 500 Program S3 + 200 S2 Baru</p>
              <p class="text-[10px] text-muted mt-1">Generasi pertama resmi menyandang gelar Doktor dan mulai mengabdi di daerah asal.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2031</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Ekspansi Pengabdian</h4>
              <p class="text-xs text-success font-semibold mt-1">🎓 182 Sudah Ph.D. + 600 Program S3 + 200 S2 Baru</p>
              <p class="text-[10px] text-muted mt-1">Penyebaran Doktor Pendidikan untuk akselerasi numerasi dasar secara luas.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2032</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Puncak Transisi S2</h4>
              <p class="text-xs text-success font-semibold mt-1">🎓 382 Sudah Ph.D. + 600 Program S3 + 18 S2 Baru</p>
              <p class="text-[10px] text-muted mt-1">Tahun terakhir seleksi masuk beasiswa magister baru.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2033</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Fokus Kelulusan Doktoral</h4>
              <p class="text-xs text-success font-semibold mt-1">🎓 582 Sudah Ph.D. + 418 Program S3</p>
              <p class="text-[10px] text-muted mt-1">Lebih dari separuh target Doktor telah lulus dan memimpin reformasi lokal.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2034</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Desentralisasi Riset</h4>
              <p class="text-xs text-success font-semibold mt-1">🎓 782 Sudah Ph.D. + 218 Program S3</p>
              <p class="text-[10px] text-muted mt-1">Karya tulis dan kurikulum sains diaplikasikan meluas.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-badge">2035</div>
            <div class="timeline-content glass-panel">
              <h4 class="text-white font-bold">Fase Akhir Doktoral</h4>
              <p class="text-xs text-success font-semibold mt-1">🎓 982 Sudah Ph.D. + 18 Program S3</p>
              <p class="text-[10px] text-muted mt-1">Disertasi akhir seluruh sisa mahasiswa doktoral beasiswa.</p>
            </div>
          </div>

          <div class="timeline-item goal">
            <div class="timeline-badge">2036</div>
            <div class="timeline-content glass-panel border-gold/40">
              <h4 class="text-gold font-bold">🏆 target 1.000 Doktor Tercapai!</h4>
              <p class="text-xs text-white font-semibold mt-1">1.000 Doktor Guru (Ph.D.) Aktif Mengabdi di Pelosok</p>
              <p class="text-[10px] text-muted mt-1">Transformasi total kualitas pendidikan dasar, pengentasan math anxiety, dan penyetaraan literasi numerasi di seluruh pelosok Indonesia secara mandiri dan berkelanjutan.</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Map Section -->
  <section class="section-padding">
    <div class="container">
      <InteractiveMap />
    </div>
  </section>

  <!-- Roadmap Timeline Section -->
  <section class="section-padding roadmap-section relative z-10">
    <div class="container">
      <div class="section-header text-center mb-12">
        <h2 class="text-gold text-2xl md:text-3xl font-serif">Alur Perjalanan Visi 1.000 Doktor Guru</h2>
        <p class="max-w-2xl mx-auto mt-2 text-sm text-secondary">Bagaimana gotong royong kita mendampingi mutiara terpendam dari pelosok kampung hingga meraih puncak ilmu pengetahuan demi daerah asal mereka.</p>
      </div>

      <div class="roadmap-grid">
        <div class="glass-panel roadmap-card">
          <div class="roadmap-icon bg-amber-500/10 text-amber-400">1</div>
          <h4 class="font-serif font-bold text-white mt-4 mb-2">Penjaringan Pelosok</h4>
          <p class="text-xs text-muted leading-relaxed">Menemukan guru-guru tangguh bertalenta (mutiara terpendam) langsung dari kampung dan daerah 3T.</p>
        </div>

        <div class="glass-panel roadmap-card border-amber-500/20">
          <div class="roadmap-icon bg-blue-500/10 text-blue-400">2</div>
          <h4 class="font-serif font-bold text-white mt-4 mb-2">Studi Magister (S2)</h4>
          <p class="text-xs text-muted leading-relaxed">Membiayai studi lanjut S2 secara gotong royong (UPI) serta skema kemitraan khusus (Columbia University) yang sedang berjalan saat ini.</p>
        </div>

        <div class="glass-panel roadmap-card">
          <div class="roadmap-icon bg-purple-500/10 text-purple-400">3</div>
          <h4 class="font-serif font-bold text-white mt-4 mb-2">Studi Doktoral (S3)</h4>
          <p class="text-xs text-muted leading-relaxed">Membantu pendanaan riset dan beasiswa S3 untuk meraih gelar Ph.D. di universitas terbaik dunia.</p>
        </div>

        <div class="glass-panel roadmap-card">
          <div class="roadmap-icon bg-success/10 text-success">4</div>
          <h4 class="font-serif font-bold text-white mt-4 mb-2">Membangun Daerah</h4>
          <p class="text-xs text-muted leading-relaxed">Para Doktor kembali ke kampung halaman untuk memimpin reformasi numerasi dan kualitas pendidikan lokal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Emotional Stories Section -->
  <section class="section-padding stories-section relative">
    <div class="container">
      <div class="section-header text-center">
        <h2>Kisah Pengabdian dari Penjuru Nusantara</h2>
        <p>Mengenal lebih dekat dedikasi dan perjalanan nyata para trainer di lapangan yang menginspirasi perubahan metode belajar matematika di tanah air.</p>
      </div>

      <div class="grid-cols-2 stories-grid">
        {realStories.map(story => (
          <div class="glass-panel story-card overflow-hidden">
            <div class="story-image-wrapper">
              <img src={story.image} alt={story.title} class="story-image" />
              <span class="story-location-badge">
                {story.location}
              </span>
            </div>
            <div class="story-info">
              <h3>{story.title}</h3>
              <p class="story-text">{story.fullStory}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Books Section -->
  <section class="section-padding books-section relative z-10 border-t border-white/5 bg-gradient-to-b from-color-bg-dark to-primary/20">
    <div class="container">
      <div class="section-header text-center mb-12">
        <h2 class="text-gold text-2xl md:text-3xl font-serif">Pustaka Dokumentasi & Buku Testimoni</h2>
        <p class="max-w-2xl mx-auto mt-2 text-sm text-secondary">
          Unduh dan baca kisah-kisah perjuangan lengkap, dokumentasi pengimbasan, serta testimoni jujur guru dan anak didik dari 4 volume buku resmi GASING.
        </p>
      </div>

      <div class="books-grid">
        {bookStories.map(book => (
          <div class="glass-panel book-card p-6 flex flex-col justify-between items-center text-center">
            <div class="book-cover-wrapper mb-4">
              <img src={book.image} alt={book.title} class="book-cover" />
            </div>
            <div class="book-info-block flex-1 flex flex-col justify-between">
              <div>
                <h4 class="font-serif font-bold text-white text-sm mb-2">{book.title.replace('Buku: ', '')}</h4>
                <p class="text-[11px] text-muted leading-relaxed mb-4">{book.excerpt}</p>
              </div>
              <a href={book.pdfUrl} target="_blank" class="download-book-btn w-full justify-center">
                <span>📖 Baca Buku (PDF)</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Board of Directors Section -->
  <section class="section-padding board-section">
    <div class="container">
      <div class="section-header text-center">
        <h2>Dewan Direksi & Pembina</h2>
        <p>Dipimpin langsung oleh pencipta metode GASING serta diawasi oleh komite independen untuk menjamin penyaluran dana 100% transparan.</p>
      </div>

      <div class="grid-cols-3 board-grid">
        {boardMembers.map(member => (
          <div class="glass-panel board-card text-center">
            <div class="member-avatar-wrapper">
              <img src={member.image} alt={member.name} class="member-avatar" />
            </div>
            <h3>{member.name}</h3>
            <span class="member-role text-gold">{member.role}</span>
            <p class="member-desc text-xs mt-3">{member.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Styling */
  .hero-section {
    padding: 100px 0 60px 0;
  }

  .hero-glow {
    background: radial-gradient(circle at center, rgba(245, 158, 11, 0.08) 0%, transparent 60%);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 100px;
    color: var(--color-text-gold);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: 2.8rem;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }
    .hero-subtitle {
      font-size: 0.95rem;
    }
    .hero-actions {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    .hero-actions a {
      width: 100%;
      max-width: 280px;
    }
  }

  /* Statistics Grid */
  .statistics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    margin-top: 20px;
  }

  .stat-card {
    padding: 24px;
    border-radius: var(--border-radius-md);
  }

  .stat-value {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .stat-desc {
    color: var(--color-text-muted);
  }

  /* Section Header */
  .section-header {
    max-width: 650px;
    margin: 0 auto 48px auto;
  }

  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .section-header p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  /* Stories Section */
  .stories-section {
    background: radial-gradient(circle at bottom, rgba(16, 185, 129, 0.03) 0%, transparent 50%);
  }

  .grid-cols-2 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
    gap: 32px;
  }

  @media (max-width: 768px) {
    .grid-cols-2 {
      grid-template-columns: 1fr;
    }
  }

  .story-card {
    border-radius: var(--border-radius-lg);
  }

  .story-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1.8;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .story-image {
    width: 100%;
    height: 100%;
    object-cover: cover;
    transition: var(--transition-smooth);
  }

  .story-card:hover .story-image {
    transform: scale(1.03);
  }

  .story-location-badge {
    position: absolute;
