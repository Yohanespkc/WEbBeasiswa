---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Website penggalangan dana Beasiswa S2 & S3 untuk para Trainer GASING Indonesia." } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Beasiswa Trainer GASING</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph Metadata -->
    <meta property="og:title" content={`${title} | Beasiswa Trainer GASING`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/images/hero.png" />
  </head>
  <body>
    <!-- Navbar Header -->
    <header class="navbar-header glass-panel">
      <div class="container nav-container">
        <a href="/" class="logo">
          <span class="logo-accent">Beasiswa</span> GASING
        </a>
        <nav class="nav-links">
          <a href="/">Beranda</a>
          <a href="/trainers">Penerima Beasiswa</a>
          <a href="/transparansi">Transparansi</a>
          <a href="/donasi" class="btn btn-primary nav-btn">Donasi Sekarang</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container footer-container">
        <div class="footer-brand">
          <h3>Beasiswa Trainer GASING</h3>
          <p>Membantu para trainer melanjutkan pendidikan S2 & S3 demi transformasi numerasi 514 Kabupaten/Kota di Indonesia.</p>
        </div>
        <div class="footer-transparency glass-panel">
          <h4>🛡️ Pernyataan Transparansi 100%</h4>
          <p>Seluruh dana publik yang masuk disalurkan 100% khusus untuk membiayai SPP kuliah, biaya hidup studi, buku, dan riset para penerima beasiswa. 0% potongan biaya administrasi platform.</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Yayasan Surya Institute. All rights reserved. Powered by Cloudflare Edge & D1 SQLite.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .navbar-header {
    position: sticky;
    top: 16px;
    z-index: 100;
    margin: 16px auto;
    width: calc(100% - 32px);
    max-width: 1200px;
    border-radius: var(--border-radius-sm);
    padding: 12px 0;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .logo-accent {
    color: var(--color-accent-gold);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-links a {
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-accent-gold);
  }

  .nav-btn {
    padding: 8px 16px;
    font-size: 0.9rem;
  }

  /* Footer Styling */
  .footer {
    background-color: #040812;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 60px 0 20px 0;
    margin-top: 80px;
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
    margin-bottom: 40px;
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .nav-links {
      gap: 16px;
    }
    .nav-btn {
      display: none; /* Hide on mobile navbar for layout cleaness */
    }
  }

  .footer-brand h3 {
    font-size: 1.5rem;
    margin-bottom: 16px;
    color: var(--color-text-primary);
  }

  .footer-transparency {
    padding: 24px;
    border-color: rgba(16, 185, 129, 0.2); /* Highlight success green */
  }

  .footer-transparency h4 {
    color: var(--color-success);
    margin-bottom: 12px;
    font-family: var(--font-sans);
  }

  .footer-bottom {
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 20px;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
</style>
