---
import Layout from '../../layouts/Layout.astro';
import { TARGET_FUNDING_PER_TRAINER_UPI } from '../../data/constants';

// Force SSR for request-time database queries
export const prerender = false;

interface Trainer {
  id: number;
  name: string;
  photo_url: string;
  major: string;
  university: string;
  bio: string;
  story_emotional: string;
  home_regency: string;
  home_province: string;
  target_funding: number;
  current_funding: number;
  is_funded: number;
  gpa: number;
}

let trainers: Trainer[] = [];
let dbError = "";

import { env } from 'cloudflare:workers';

try {
  if (env && env.DB) {
    const { results } = await env.DB.prepare("SELECT * FROM trainers ORDER BY is_funded ASC, id ASC").all();
    trainers = (results as unknown as Trainer[]).map(t => {
      if (t.university !== 'Columbia University') {
        t.target_funding = TARGET_FUNDING_PER_TRAINER_UPI;
      }
      return t;
    });
  } else {
    dbError = "Database D1 tidak terdeteksi. Pastikan server dijalankan dengan Cloudflare Locals.";
  }
} catch (err: any) {
  console.error("Database query error:", err);
  dbError = `Gagal memuat data dari database: ${err.message}`;
}
---

<Layout title="Talenta Gasing Nusantara" description="Daftar lengkap para trainer GASING Indonesia yang bertumbuh menempuh jenjang S2 & S3 untuk memajukan pendidikan nasional.">
  <section class="section-padding">
    <div class="container">
      
      <!-- Responsive Header Grid -->
      <div class="trainers-header-grid mb-12">
        <div class="trainers-header-left">
          <span class="badge">👨‍🏫 TALENTA GASING NUSANTARA</span>
          <h2>Para Pembawa Perubahan Pendidikan</h2>
          <p class="mt-4 text-sm text-secondary leading-relaxed">
            Mereka adalah para trainer tangguh yang telah melatih ribuan anak di pedalaman Indonesia. Kami mendampingi mereka dalam melanjutkan studi S2 & S3 untuk dicetak menjadi agen transformasi pendidikan nasional yang berintegritas tinggi.
          </p>
        </div>

        <!-- Compact Pooled Fund Policy Notice -->
        <div class="glass-panel trainers-header-right p-6 border border-amber-500/20 bg-amber-500/5 rounded-xl flex flex-col gap-4">
          <h4 class="font-serif text-amber-500 font-bold text-sm mb-1 flex items-center gap-2">
            📢 Kebijakan Penyaluran Donasi
          </h4>
          
          <div class="flex flex-col gap-3">
            <!-- UPI Item -->
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="badge-policy bg-amber-500/10 text-amber-600 border border-amber-500/20">UPI (80 AT)</span>
                <strong class="text-xs text-primary">Dana Bersama (Pooled Fund)</strong>
              </div>
              <p class="text-xs text-muted leading-relaxed">
                Setiap donasi untuk trainer UPI digabungkan secara gotong royong agar terbagi rata demi asas keadilan dan kesetaraan semua penerima.
              </p>
            </div>
            
            <!-- Columbia Item -->
            <div class="border-divider pt-3">
              <div class="flex items-center gap-2 mb-1">
                <span class="badge-policy bg-blue-500/10 text-blue-600 border border-blue-500/20" style="background: rgba(59, 130, 246, 0.08); border-color: rgba(59, 130, 246, 0.2); color: #2563eb;">Columbia (2 AT)</span>
                <strong class="text-xs text-primary">Donasi Langsung (Direct Fund)</strong>
              </div>
              <p class="text-xs text-muted leading-relaxed">
                Khusus untuk <strong>Livi & Witnny</strong>, donasi disalurkan 100% langsung ke individu mereka (tidak dibagi atau digabung ke Dana Bersama UPI).
              </p>
            </div>
          </div>
        </div>
      </div>

      {dbError && (
        <div class="error-banner glass-panel">
          <p>⚠️ {dbError}</p>
          <p class="text-xs mt-2 text-muted">Menampilkan data simulasi lokal...</p>
        </div>
      )}

      <!-- Trainers Grid -->
      <div class="grid-cols-3 trainers-grid">
        {trainers.length > 0 ? (
          trainers.map((trainer) => {
            let percent = 0;
            if (trainer.university === 'Columbia University') {
              const targetInIDR = trainer.target_funding * 16000; // 1 USD = Rp 16.000
              percent = Math.min(100, Math.round((trainer.current_funding / targetInIDR) * 100));
            } else {
              percent = Math.min(100, Math.round((trainer.current_funding / trainer.target_funding) * 100));
            }
            return (
              <div class="glass-panel trainer-card overflow-hidden flex flex-col justify-between">
                <div>
                  <div class="trainer-avatar-box">
                    <img src={trainer.photo_url} alt={trainer.name} class="trainer-avatar" />
                    {trainer.is_funded === 1 && (
                      <span class="funded-badge">🎉 Didanai Penuh</span>
                    )}
                  </div>
                  <div class="trainer-body">
                    <span class="trainer-loc">{trainer.home_regency}, {trainer.home_province}</span>
                    <h3>{trainer.name} <span class="text-xs text-gold/80 font-normal ml-1">(IPK {trainer.gpa ? trainer.gpa.toFixed(2).replace('.', ',') : '0,00'})</span></h3>
                    <p class="trainer-major text-gold">{trainer.major}</p>
                    <p class="trainer-univ text-xs text-muted mb-4">{trainer.university}</p>
                    <p class="trainer-bio text-sm leading-relaxed">{trainer.bio}</p>
                  </div>
                </div>

                <div class="trainer-footer">
                  <!-- Progress Bar -->
                  <div class="funding-progress">
                    <div class="progress-lbl text-xs flex justify-between mb-1">
                      <span>Terkumpul: <strong>Rp {Math.round(trainer.current_funding).toLocaleString('id-ID')}</strong></span>
                    </div>
                    <div class="progress-bar-bg">
                      <div class="progress-bar-fill shimmer-bar" style={`width: ${percent}%;`}></div>
                    </div>
                    <div class="progress-target text-[10px] text-muted text-right mt-1">
                      {trainer.university === 'Columbia University' 
                        ? `Kebutuhan: $${Math.max(0, Math.round(trainer.target_funding - (trainer.current_funding / 16000))).toLocaleString('en-US')} USD` 
                        : `Kebutuhan: Rp ${Math.max(0, Math.round(trainer.target_funding - trainer.current_funding)).toLocaleString('id-ID')}`}
                    </div>
                  </div>

                  <a href={`/trainers/${trainer.id}`} class="btn btn-secondary w-full text-center mt-4">
                    Lihat Profil Lengkap
                  </a>
                </div>
              </div>
            );
          })
        ) : (
          !dbError && <p class="text-center text-muted">Belum ada data trainer terdaftar.</p>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .trainers-header-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
  }

  .trainers-header-right {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .border-divider {
    border-top: 1px solid rgba(217, 119, 6, 0.15);
  }

  .badge-policy {
    display: inline-block;
    padding: 2px 6px;
    background: rgba(217, 119, 6, 0.08);
    border: 1px solid rgba(217, 119, 6, 0.2);
    border-radius: 4px;
    color: var(--color-text-gold);
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-family: var(--font-sans);
  }

  .trainers-header-left h2 {
    font-size: 2.2rem;
    line-height: 1.2;
    margin-top: 8px;
    margin-bottom: 8px;
  }

  @media (max-width: 768px) {
    .trainers-header-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .badge {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 100px;
    color: var(--color-text-gold);
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .error-banner {
    padding: 20px;
    border-color: rgba(239, 68, 68, 0.3);
    background: rgba(239, 68, 68, 0.05);
    color: var(--color-danger);
    margin-bottom: 32px;
    text-align: center;
    border-radius: var(--border-radius-md);
  }

  .trainer-card {
    border-radius: var(--border-radius-lg);
    padding: 0;
    min-height: 520px;
  }

  .trainer-avatar-box {
    position: relative;
    width: 100%;
    aspect-ratio: 1.1;
    overflow: hidden;
    background-color: rgba(15, 23, 42, 0.02);
    border-bottom: 1px solid rgba(15, 23, 42, 0.05);
  }

  .trainer-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .funded-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 6px 12px;
    background: rgba(16, 185, 129, 0.9);
    backdrop-filter: blur(4px);
    border-radius: var(--border-radius-sm);
    color: #ffffff;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .trainer-body {
    padding: 24px;
  }

  .trainer-loc {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .trainer-body h3 {
    font-size: 1.3rem;
    margin-bottom: 4px;
  }

  .trainer-major {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .trainer-bio {
    color: var(--color-text-secondary);
  }

  .trainer-footer {
    padding: 24px;
    border-top: 1px solid rgba(15, 23, 42, 0.05);
    background: rgba(15, 23, 42, 0.02);
  }

  /* Progress Bar styling */
  .progress-bar-bg {
    width: 100%;
    height: 8px;
    background: rgba(15, 23, 42, 0.08);
    border-radius: 100px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    border-radius: 100px;
  }

  .w-full {
    width: 100%;
  }
</style>
