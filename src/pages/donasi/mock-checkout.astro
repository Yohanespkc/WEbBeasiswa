---
import Layout from '../../layouts/Layout.astro';

// Force SSR to read request query params
export const prerender = false;

const url = new URL(Astro.request.url);
const orderId = url.searchParams.get('orderId') || "";
const amount = Number(url.searchParams.get('amount') || "0");
const name = url.searchParams.get('name') || "Donatur";
const method = url.searchParams.get('method') || "bca";

let paymentMethodName = "";
let instructionDetails: { label: string; val: string; isMono?: boolean }[] = [];
let noteText = "";

if (method === 'bca') {
  paymentMethodName = "BCA Virtual Account";
  instructionDetails = [
    { label: "Metode Pembayaran", val: "BCA Virtual Account (Simulasi)" },
    { label: "Nomor Virtual Account", val: "118-0855-9008-2026", isMono: true },
    { label: "Nama Rekening Penerima", val: "Yayasan 1000PhD Guru" }
  ];
  noteText = "* Petunjuk Pembayaran: Masuk ke m-BCA > Transfer > BCA Virtual Account. Masukkan nomor VA di atas dan konfirmasi nominal pembayaran.";
} else if (method === 'bni') {
  paymentMethodName = "BNI Virtual Account";
  instructionDetails = [
    { label: "Metode Pembayaran", val: "BNI Virtual Account (Simulasi)" },
    { label: "Nomor Virtual Account", val: "827-0855-9008-2026", isMono: true },
    { label: "Nama Rekening Penerima", val: "Yayasan 1000PhD Guru" }
  ];
  noteText = "* Petunjuk Pembayaran: Masuk ke BNI Mobile Banking > Transfer > Virtual Account Billing. Masukkan nomor VA di atas dan bayar.";
} else if (method === 'bri') {
  paymentMethodName = "BRI Virtual Account (BRIVA)";
  instructionDetails = [
    { label: "Metode Pembayaran", val: "BRI Virtual Account (Simulasi)" },
    { label: "Nomor Virtual Account (BRIVA)", val: "779-0855-9008-2026", isMono: true },
    { label: "Nama Rekening Penerima", val: "Yayasan 1000PhD Guru" }
  ];
  noteText = "* Petunjuk Pembayaran: Masuk ke BRImo > Pembayaran > BRIVA. Masukkan nomor BRIVA di atas dan bayar.";
} else if (method === 'dana') {
  paymentMethodName = "DANA E-Wallet";
  instructionDetails = [
    { label: "Metode Pembayaran", val: "DANA E-Wallet (Simulasi)" },
    { label: "Nomor HP DANA", val: "0855-9008-2026", isMono: true },
    { label: "Nama Akun Penerima", val: "Yayasan 1000PhD Guru" }
  ];
  noteText = "* Petunjuk Pembayaran: Buka aplikasi DANA > Kirim > Kirim ke Teman / Nomor HP. Masukkan nomor HP penerima di atas dan konfirmasi.";
} else if (method === 'ovo') {
  paymentMethodName = "OVO E-Wallet";
  instructionDetails = [
    { label: "Metode Pembayaran", val: "OVO E-Wallet (Simulasi)" },
    { label: "Nomor HP OVO", val: "0855-9008-2026", isMono: true },
    { label: "Nama Akun Penerima", val: "Yayasan 1000PhD Guru" }
  ];
  noteText = "* Petunjuk Pembayaran: Buka aplikasi OVO > Transfer > Ke Sesama OVO. Masukkan nomor HP penerima di atas dan konfirmasi.";
} else if (method === 'intl') {
  paymentMethodName = "International SWIFT Bank Transfer";
  instructionDetails = [
    { label: "Metode Pembayaran", val: "International SWIFT Transfer (Simulasi)" },
    { label: "Nama Bank Penerima", val: "Bank Central Asia (BCA)" },
    { label: "SWIFT Code / BIC", val: "CENAIJAXXX", isMono: true },
    { label: "Nomor Rekening (Account Number)", val: "118-3012-9008", isMono: true },
    { label: "Nama Penerima (Beneficiary)", val: "Yayasan 1000PhD Guru" },
    { label: "Alamat Bank & Penerima", val: "Jakarta, Indonesia" }
  ];
  noteText = "* Petunjuk Internasional: Untuk transfer dari luar negeri, gunakan kode SWIFT dan nomor rekening di atas. Anda juga dapat menggunakan platform seperti Wise (transferwise.com) atau PayPal untuk mentransfer secara langsung ke rekening di atas dengan biaya lebih rendah dan konversi otomatis ke IDR.";
}
---

<Layout title="Simulasi Pembayaran Donasi" description="Halaman sandbox pembayaran donasi untuk simulasi transfer beasiswa.">
  <section class="section-padding">
    <div class="container max-w-md">
      
      <div class="checkout-header text-center mb-8">
        <span class="badge">⚙️ SANDBOX SIMULATOR</span>
        <h2>Instruksi Pembayaran</h2>
        <p>Gunakan petunjuk di bawah ini untuk mensimulasikan transfer dana donasi Anda.</p>
      </div>

      <!-- Mock Invoice Card -->
      <div class="glass-panel invoice-card p-8">
        <div class="invoice-summary text-center mb-6">
          <span class="text-xs text-muted block uppercase tracking-wider">TOTAL INVOICE DONASI</span>
          <h2 class="text-gold font-serif text-2xl my-2">Rp {amount.toLocaleString('id-ID')}</h2>
          <span class="text-[10px] text-muted font-mono block">Order ID: {orderId}</span>
        </div>

        <div class="invoice-details mb-6">
          {instructionDetails.map(item => (
            <div class="invoice-row flex justify-between py-2 border-b border-white/5">
              <span class="lbl text-sm text-muted">{item.label}</span>
              <span class={`val text-sm ${item.isMono ? 'font-mono font-bold text-gold' : 'font-semibold text-white'}`}>{item.val}</span>
            </div>
          ))}
        </div>

        {noteText && (
          <div class="note-box glass-panel p-4 mb-6 text-xs text-muted leading-relaxed text-left border border-white/5 bg-white/2 rounded">
            {noteText}
          </div>
        )}

        <div class="checkout-actions">
          <button class="btn btn-primary w-full text-center py-3 font-bold" id="simulate-success-btn">
            🟢 Simulasikan Pembayaran Sukses (D1)
          </button>
          
          <a href="/donasi" class="btn btn-secondary w-full text-center mt-3 py-2 text-xs">
            Batalkan Pembayaran
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script define:vars={{ orderId, amount }}>
  document.addEventListener('DOMContentLoaded', () => {
    const successBtn = document.getElementById('simulate-success-btn');

    if (!successBtn) return;

    successBtn.addEventListener('click', async () => {
      successBtn.disabled = true;
      successBtn.textContent = "Mengirim Konfirmasi Webhook...";

      try {
        // Send simulated success event to our local D1 webhook endpoint
        const response = await fetch('/api/webhook', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            orderId: orderId,
            status: 'settlement'
          })
        });

        const data = await response.json();
        
        if (!response.ok) {
          throw new Error(data.error || "Gagal mengupdate database.");
        }

        // Redirect to success landing page
        window.location.href = `/donasi/sukses?orderId=${orderId}&amount=${amount}`;

      } catch (err) {
        alert(`Gagal simulasi: ${err.message}`);
        successBtn.disabled = false;
        successBtn.textContent = "Simulasikan Pembayaran Sukses (D1)";
      }
    });
  });
</script>

<style>
  .max-w-md {
    max-width: 480px;
    margin: 0 auto;
  }

  .checkout-header h2 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .badge {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(245, 158, 11, 0.25);
    border-radius: 100px;
    color: var(--color-text-gold);
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .invoice-card {
    border-radius: var(--border-radius-lg);
  }

  .invoice-summary {
    border-bottom: 2px dashed rgba(255, 255, 255, 0.08);
    padding-bottom: 20px;
  }

  .invoice-details {
    padding: 8px 0;
  }

  .w-full {
    width: 100%;
  }

  /* Pulsing animation on simulate success button */
  #simulate-success-btn {
    animation: pulseGlow 2s infinite ease-in-out;
  }

  @keyframes pulseGlow {
    0% { box-shadow: 0 0 10px rgba(16, 185, 129, 0.2); }
    50% { box-shadow: 0 0 25px rgba(16, 185, 129, 0.6); }
    100% { box-shadow: 0 0 10px rgba(16, 185, 129, 0.2); }
  }
</style>
